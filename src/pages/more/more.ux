			  <img src="/common/images/enter.png" style="width:32px;height: 32px;" static/>
		  </list-item>

		  <list-item class="item" type="item">
			  <div class="item-content">
				  <text class="itemtext" static>老师屏增强</text>
				  <text class="itemtext2">熄屏自动退出</text>
			  </div>
			  <img src="{{teacherScreenAdvanced ? '/common/images/Switch_ON.png' : '/common/images/Switch_OFF.png'}}" @click="toggleTeacherScreen" style="width:40px;height: 30px;" />
		  </list-item>

		  <list-item class="item" @click="routerTo('edgeSwipeSetting')" type="item">
