<template>
  <div class="page" style="flex-direction: column;">
    <img if="{{allBooks.length == 0}}" static src="/common/images/empty.png" style="position: absolute;left: 58px;top: 186px;width: 92px;height: 92px;" />
    <text if="{{allBooks.length == 0}}" static style="position: absolute;left: 0px;top: 289px;width: 212px;line-height: 42px;font-weight:bold;font-size:22px;color:white;text-align:center;">书架空空</text>
    
    <list class="list" if="{{allBooks.length > 0}}">
      <list-item type="tip" if="{{showStorageWarning && isStorageLow && (!selectedCategory || displayMode !== 'category')}}" class="item" style="background-color: #ad0000;">
        <text class="itemtext" style="lines: 2;">实际可用存储空间不足，电子书将无法正常使用。</text>
      </list-item>
      
			<list-item type="search" class="item search-item" @click="openSearch" if="{{showSearchBar}}">
				<div class="search-content">
					<text class="search-placeholder">搜索...</text>
				</div>
			</list-item>

      <list-item type="back" if="{{displayMode === 'category' && selectedCategory}}" class="item" @click="backToCategoryList" style="height: 72px;">
        <text class="itemtext">← 返回分类</text>
      </list-item>

      <list-item type="book" for="{{visibleBooks}}" class="item {{ (shelfStyle === 'cover' && $item.hasRealCover) ? 'cover-item' : '' }}" @click="handleItemClick($item)" onlongpress="onItemLongPress($item)">
        <img if="{{shelfStyle === 'cover' && $item.hasRealCover}}" class="cover-image" src="internal://files/books/{{$item.dirName}}/{{$item.coverFileName}}" />
        
        <div class="{{ (shelfStyle === 'cover' && $item.hasRealCover) ? 'cover-content' : 'item-content' }}" style="{{ ($item.colorBg && !$item.hasRealCover) ? 'background-color: ' + $item.colorBg + '; border-radius: 16px; padding: 6px 8px;' : '' }}">
          <marquee if="{{shelfMarqueeEnabled && !$item.isCategory}}" scrollamount="22" class="itemtext" text-offset="25">{{$item.name}}</marquee>
          <text else class="itemtext">{{$item.name}}</text>
          
          <marquee if="{{shelfMarqueeEnabled && !$item.isCategory}}" scrollamount="40" text-offset="25" class="itemtext2">{{getProgressSubtitle($item)}}</marquee>
          <text else class="itemtext2">{{getProgressSubtitle($item)}}</text>
          <div if="{{uxShelfProgressBar && !$item.isCategory && getBookProgressPercent($item) > 0}}" style="width: 100%; height: 4px; background-color: rgba(255,255,255,0.15); border-radius: 2px; margin-top: 4px;">
            <div style="width: {{getBookProgressPercent($item) * 1.68}}px; height: 4px; background-color: rgba(46, 204, 113, 0.8); border-radius: 2px;"></div>
          </div>
        </div>
      </list-item>

      <list-item type="pagination" class="pagination-container" if="{{totalPages > 1}}">
        <div class="pagination-controls">
          <img src="/common/images/pre.png" if="{{currentPage > 0}}" @click="prevPage" class="pagination-button" />
          <text class="pagination-text">{{currentPage + 1}} / {{totalPages}}</text>
          <img src="/common/images/next.png" if="{{currentPage < totalPages - 1}}" @click="nextPage" class="pagination-button" />
        </div>
      </list-item>
    </list>

    <img static src="/common/images/hd.png" style="position: absolute;left: 0px;top: 0px;width: 212px;height: 102px;" @click="goBack" />
    <img static src="/common/images/more.png" @click="routerTo('more')" style="position: absolute;left: 67px;top: 418px;width: 72px;height: 72px;" />
    <text style="position: absolute;top: 16px;width: 212px;line-height: 32px;font-weight:bold;font-size:18px;color:rgba(255,255,255,0.6);text-align:center;">{{nowTime}}</text>
    <text static style="position: absolute;top: 36px;width: 212px;line-height: 42px;font-weight:bold;font-size:26px;color:white;text-align:center;">电子书</text>
  </div>
</template>

<script>
import router from '@system.router';
import bookStorage from '../../utils/bookStorage.js'
import storage from '../../utils/storage.js';
import chapterManager from '../../utils/chapterManager.js';
import device from '@system.device';
import { calculateStorageInfo, isStorageLow } from '../../utils/storageUtils.js';
import vibrator from '@system.vibrator';
import { goBackWithVibration } from '../../utils/common.js';

export default {
  private: {
    nowTime: "00:00",
    timer: null,
		timeFormat: '24h',
    shelfStyle: 'list',
    isNavigating: false,
    allBooks: [],
    visibleBooks: [],
    currentPage: 0,
    totalPages: 1,
    pageSize: 5,
    lastReadOnTop: true,
    shelfMarqueeEnabled: false,
    displayMode: 'all',
    categories: [],
    selectedCategory: null,
    categoryBooks: [],
    lastReadBook: null,
    homeProgressMode: 'book',
    showStorageWarning: true,
    isStorageLow: false,
    categoryPagination: false,
    currentModeList: [],
    refreshMode: 'onExit',
		showSearchBar: true,
    progressSubtitleCache: {},
    lastDeviceInfoTs: 0,
    storageInfoLoaded: false,
    categoryCountCache: null,
    colorfulShelfEnabled: false,
    bookColorMap: {},
    colorIndexCounter: 0,
    uxShelfProgressBar: false
  },
  updateTime() {
    const date = new Date();
		let hours = date.getHours();
		let minutes = date.getMinutes();
		if (this.timeFormat === '12h') {
			let ampm = hours >= 12 ? '下午' : '上午';
			hours = hours % 12;
			hours = hours ? hours : 12;
			minutes = minutes < 10 ? '0' + minutes : minutes;
			this.nowTime = `${ampm} ${hours}:${minutes}`;
		} else {
			hours = hours < 10 ? '0' + hours : hours;
			minutes = minutes < 10 ? '0' + minutes : minutes;
			this.nowTime = `${hours}:${minutes}`;
		}
  },
  onInit() {
		storage.get({
			key: 'EBOOK_TIME_FORMAT',
			success: (data) => {
				if(data) this.timeFormat = data;
				this.updateTime();
			},
			fail: () => {
				this.updateTime();
			}
		});
    this.timer = setInterval(() => { this.updateTime(); }, 1000);
    bookStorage.load();
  },
  onDestroy() {
    if (this.timer) { clearInterval(this.timer); this.timer = null; }
    this.progressSubtitleCache = null;
    this.categoryCountCache = null;
    this.allBooks = null;
    this.visibleBooks = null;
    this.currentModeList = null;
    this.categories = null;
    global.runGC();
  },
  onShow() {
    this.isNavigating = false;
    const shouldRestoreCategory = globalThis.fromCategoryPage && globalThis.selectedCategory;
    const categoryToRestore = shouldRestoreCategory ? globalThis.selectedCategory : null;
    const categoryPageToRestore = shouldRestoreCategory && typeof globalThis.categoryPage === 'number' ? globalThis.categoryPage : null;
    const shouldRestoreHomePage = globalThis.fromHomePage && typeof globalThis.homePage === 'number';
    const homePageToRestore = shouldRestoreHomePage ? globalThis.homePage : null;

    if (shouldRestoreCategory) {
      globalThis.fromCategoryPage = false;
      globalThis.selectedCategory = null;
      globalThis.categoryPage = null;
    }
    if (shouldRestoreHomePage) {
      globalThis.fromHomePage = false;
      globalThis.homePage = null;
    }
    if (!shouldRestoreHomePage && !shouldRestoreCategory) {
      this.currentPage = 0;
    }

    this.loadSettingsAndFiles().then(() => {
      const shouldRefresh = this.shouldRefreshShelf();
      const loadLogic = () => {
        if (shouldRestoreCategory && categoryToRestore) {
            this.displayMode = 'category';
            this.selectedCategory = categoryToRestore;
            if (categoryPageToRestore !== null) this.currentPage = categoryPageToRestore;
            this.updateCategoryView();
        } else if (shouldRestoreHomePage && homePageToRestore !== null && this.displayMode === 'all') {
            this.loadPage(homePageToRestore);
        }
        this.loadDeviceInfo();
      };

      if (shouldRefresh || this.allBooks.length === 0) {
        this.loadFileList().then(loadLogic);
      } else {
        loadLogic();
      }
    });
  },
  getStorage(key, defaultValue) {
    return new Promise((resolve) => {
      storage.get({ key: key, success: (data) => resolve(data || defaultValue), fail: () => resolve(defaultValue) });
    });
  },
  async loadSettingsAndFiles() {
    const results = await Promise.all([
      this.getStorage('EBOOK_SHELF_PAGE_SIZE', '5'),
      this.getStorage('EBOOK_SHELF_STYLE', 'list'),
      this.getStorage('EBOOK_TOP_LAST_READ', 'true'),
      this.getStorage('EBOOK_SHELF_MARQUEE_ENABLED', 'false'),
      this.getStorage('EBOOK_HOME_DISPLAY_MODE', 'all'),
      this.getStorage('EBOOK_HOME_PROGRESS_MODE', 'book'),
      this.getStorage('EBOOK_SHOW_STORAGE_WARNING', 'true'),
      this.getStorage('EBOOK_CATEGORY_PAGINATION', 'false'),
      this.getStorage('EBOOK_SHELF_REFRESH_MODE', 'onExit'),
			this.getStorage('EBOOK_HOME_SEARCH_ENABLED', 'true'),
			this.getStorage('EBOOK_COLORFUL_SHELF_ENABLED', 'false'),
			this.getStorage('EBOOK_BOOK_COLOR_MAP', '{}'),
			this.getStorage('EBOOK_UX_SHELF_PROGRESS_BAR', 'false')
    ]);
    this.pageSize = parseInt(results[0]);
    this.shelfStyle = results[1];
    this.lastReadOnTop = results[2] === 'true';
    this.shelfMarqueeEnabled = results[3] === 'true';
    this.displayMode = results[4] || 'all';
    this.homeProgressMode = results[5] || 'book';
    this.showStorageWarning = results[6] === 'true';
    this.categoryPagination = results[7] === 'true';
    this.refreshMode = results[8] || 'onExit';
		this.showSearchBar = results[9] === 'true';
		this.colorfulShelfEnabled = results[10] === 'true';
		try { this.bookColorMap = JSON.parse(results[11] || '{}') } catch(e) { this.bookColorMap = {} }
		this.uxShelfProgressBar = results[12] === 'true'
  },
  shouldRefreshShelf() {
    if (this.refreshMode === 'onEnter') return true;
    else if (this.refreshMode === 'onExit') {
      if (globalThis.shouldRefreshShelf) {
        globalThis.shouldRefreshShelf = false;
        return true;
      }
      return false;
    }
    return false;
  },
  async loadFileList() {
    this.allBooks = await bookStorage.getBooks();
    this.progressSubtitleCache = {};
    this.categoryCountCache = null;
    await this.syncChapterCounts();
    this.processBooks();
    if (this.displayMode === 'category') {
      this.updateCategories();
      this.updateCategoryView();
    } else {
      this.currentModeList = this.allBooks;
      this.loadPage(this.currentPage);
    }
    global.runGC();
  },
  async syncChapterCounts() {
    if (!Array.isArray(this.allBooks) || this.allBooks.length === 0) return;

    const needCheckBooks = [];
    for (let i = 0; i < this.allBooks.length; i++) {
      const book = this.allBooks[i];
      if (!book || !book.dirName) continue;
      const storedCount = parseInt(book.chapterCount, 10) || 0;
      if (storedCount <= 0) needCheckBooks.push(book);
    }

    if (needCheckBooks.length === 0) return;

    const maxCheckCount = Math.min(3, needCheckBooks.length);
    let hasUpdates = false;

    for (let i = 0; i < maxCheckCount; i++) {
      const book = needCheckBooks[i];
      try {
        const actualCount = await chapterManager.getTotalChapters(book.dirName);
        if (actualCount > 0 && actualCount !== (parseInt(book.chapterCount, 10) || 0)) {
          book.chapterCount = actualCount;
          hasUpdates = true;
        }
      } catch (e) { }
    }

    if (hasUpdates) await bookStorage.updateBooks(this.allBooks);
  },
  processBooks() {
    this.lastReadBook = null;
    if (this.lastReadOnTop && this.allBooks.length > 0) {
      let lastReadIndex = -1;
      let latestTimestamp = 0;
      this.allBooks.forEach((book, index) => {
        book.isLastRead = false;
        if (book.progress && book.progress.lastReadTimestamp > latestTimestamp) {
          latestTimestamp = book.progress.lastReadTimestamp;
          lastReadIndex = index;
        }
      });
      if (lastReadIndex > -1) {
        const lastReadBook = this.allBooks.splice(lastReadIndex, 1)[0];
        lastReadBook.isLastRead = true;
        this.allBooks.unshift(lastReadBook);
        this.lastReadBook = lastReadBook;
      }
    }
    this.allBooks.forEach(book => {
      book.hasRealCover = !!(book.hasCover && book.coverFileName);
      if (this.colorfulShelfEnabled && !book.isCategory && book.dirName) {
        if (!this.bookColorMap[book.dirName]) {
          this.bookColorMap[book.dirName] = this.getPredefinedColor(this.colorIndexCounter++);
          storage.set({ key: 'EBOOK_BOOK_COLOR_MAP', value: JSON.stringify(this.bookColorMap) })
        }
        book.colorBg = this.bookColorMap[book.dirName]
      }
    });
  },
  updateCategories() {
    const categorySet = new Set();
    let hasUncategorized = false;
    this.allBooks.forEach(book => {
      if (book.localCategory) categorySet.add(book.localCategory);
      else hasUncategorized = true;
    });
    this.categories = Array.from(categorySet).sort();
    if (hasUncategorized) this.categories.push('未分类');
    this.categoryCountCache = null;
  },
  updateCategoryView() {
    if (this.selectedCategory) {
      this.categoryBooks = this.selectedCategory === '未分类' 
          ? this.allBooks.filter(book => !book.localCategory)
          : this.allBooks.filter(book => book.localCategory === this.selectedCategory);
      this.currentModeList = this.categoryBooks;
    } else {
      if (!this.categoryCountCache) {
        const countMap = {};
        let uncategorizedCount = 0;
        for (let i = 0; i < this.allBooks.length; i++) {
          const book = this.allBooks[i];
          if (book.localCategory) {
            countMap[book.localCategory] = (countMap[book.localCategory] || 0) + 1;
          } else {
            uncategorizedCount++;
          }
        }
        this.categoryCountCache = {
          countMap,
          uncategorizedCount
        };
      }

      const categoryItems = this.categories.map(cat => ({
        isCategory: true,
        categoryName: cat,
        name: cat,
        bookCount: cat === '未分类'
          ? this.categoryCountCache.uncategorizedCount
          : (this.categoryCountCache.countMap[cat] || 0)
      }));
      this.currentModeList = this.lastReadBook ? [this.lastReadBook, ...categoryItems] : categoryItems;
    }
    if (this.categoryPagination) {
        this.loadPage(this.currentPage);
    } else {
        this.visibleBooks = this.currentModeList;
        this.totalPages = 1;
        this.currentPage = 0;
    }
  },
  backToCategoryList() {
    this.selectedCategory = null;
    this.currentPage = 0;
    this.updateCategoryView();
  },
  handleItemClick(item) {
    if (item.isCategory) {
      this.selectedCategory = item.categoryName;
      this.currentPage = 0;
      this.updateCategoryView();
    } else {
      this.selectFile(item);
    }
  },
  roundToDecimal(num, decimalPlaces) {
    const parsed = parseFloat(num);
    return isNaN(parsed) ? (0).toFixed(decimalPlaces) : parsed.toFixed(decimalPlaces);
  },
  getChapterProgressPercent(book) {
    if (!book || !book.progress) return 0;
    let percent = parseFloat(book.progress.chapterProgressPercent);
    return isNaN(percent) ? 0 : Math.min(100, Math.max(0, percent));
  },
  getBookProgressPercent(book) {
    if (!book || !book.progress) return 0;
    const totalChapters = parseInt(book.chapterCount, 10) || 0;
    if (totalChapters <= 0) return 0;
    const chapterIndex = (typeof book.progress.chapterIndex === 'number' && book.progress.chapterIndex >= 0) ? book.progress.chapterIndex : 0;
    const chapterFraction = this.getChapterProgressPercent(book) / 100;
    const progressValue = ((chapterIndex + chapterFraction) / totalChapters) * 100;
    return Math.min(100, Math.max(0, progressValue));
  },
  getProgressSubtitle(book) {
    if (!book) return '暂无进度';
    if (book.isCategory) return `共 ${book.bookCount || 0} 本`;

    const cacheKey = `${book.dirName || ''}|${book.isLastRead ? 1 : 0}|${this.homeProgressMode}|${book.chapterCount || 0}|${book.progress && book.progress.chapterIndex != null ? book.progress.chapterIndex : -1}|${book.progress && book.progress.chapterProgressPercent != null ? book.progress.chapterProgressPercent : ''}`;
    if (this.progressSubtitleCache && this.progressSubtitleCache[cacheKey]) {
      return this.progressSubtitleCache[cacheKey];
    }

    const prefix = book.isLastRead ? '上次阅读 · ' : '';
    const progress = book.progress || {};
    let result = '';

    if (progress.chapterIndex === null || progress.chapterIndex === undefined || progress.chapterIndex < 0) {
      result = `${prefix}尚未开始`;
    } else if (this.homeProgressMode === 'chapter') {
      const chapterPercent = this.roundToDecimal(this.getChapterProgressPercent(book), 2) || 0;
      result = `${prefix}${chapterPercent}% · 本章进度`;
    } else {
      const bookPercent = this.roundToDecimal(this.getBookProgressPercent(book), 2) || 0;
      const totalChapters = parseInt(book.chapterCount, 10) || 0;
      if (totalChapters <= 0) {
        result = `${prefix}${bookPercent}% · 章节信息缺失`;
      } else {
        const currentChapter = Math.min(totalChapters, (progress.chapterIndex || 0) + 1);
        result = `${prefix}${bookPercent}% · 看到 ${currentChapter} / ${totalChapters} 章`;
      }
    }

    if (this.progressSubtitleCache) this.progressSubtitleCache[cacheKey] = result;
    return result;
  },
  loadPage(page) {
    const list = this.currentModeList || this.allBooks;
    this.totalPages = Math.ceil(list.length / this.pageSize) || 1;
    let safePage = Math.max(0, Math.min(page, this.totalPages - 1));
    if (this.totalPages > 0) {
      const start = safePage * this.pageSize;
      this.visibleBooks = list.slice(start, start + this.pageSize);
      this.currentPage = safePage;
    } else {
      this.visibleBooks = [];
      this.currentPage = 0;
    }
  },
  prevPage() {
    if (this.currentPage > 0) this.loadPage(this.currentPage - 1);
  },
  nextPage() {
    if (this.currentPage < this.totalPages - 1) this.loadPage(this.currentPage + 1);
  },
  async selectFile(item) {
    if (this.isNavigating) return;
    this.isNavigating = true;
    globalThis.enteringDetailView = true;
    if (this.displayMode === 'category' && this.selectedCategory) {
      globalThis.fromCategoryPage = true;
      globalThis.selectedCategory = this.selectedCategory;
      globalThis.categoryPage = this.currentPage;
      globalThis.fromHomePage = false;
      globalThis.homePage = null;
    } else if (this.displayMode === 'all') {
      globalThis.fromCategoryPage = false;
      globalThis.selectedCategory = null;
      globalThis.fromHomePage = true;
      globalThis.homePage = this.currentPage;
    } else {
      globalThis.fromCategoryPage = false;
      globalThis.selectedCategory = null;
      globalThis.fromHomePage = false;
      globalThis.homePage = null;
    }
    router.push({ uri: '/pages/detail', params: { name: item.dirName } });
  },
	openSearch() {
		router.push({ uri: '/pages/search' });
	},
  // Feature 5: Long press book → bookinfo
  onItemLongPress(item) {
    if (item.isCategory) return
    try { vibrator.vibrate({ mode: 'short' }) } catch(e) {}
    router.push({ uri: '/pages/bookinfo', params: { name: item.dirName } })
  },
  // Feature 9: Predefined colors for colorful shelf
  getPredefinedColor(index) {
    const colors = [
      'rgba(120, 80, 60, 0.35)', 'rgba(60, 90, 120, 0.35)', 'rgba(80, 110, 70, 0.35)',
      'rgba(100, 70, 100, 0.35)', 'rgba(70, 85, 100, 0.35)', 'rgba(90, 75, 65, 0.35)',
      'rgba(65, 95, 85, 0.35)', 'rgba(85, 70, 90, 0.35)', 'rgba(75, 90, 75, 0.35)',
      'rgba(95, 80, 70, 0.35)', 'rgba(70, 80, 95, 0.35)', 'rgba(80, 75, 85, 0.35)'
    ]
    return colors[index % colors.length]
  },
  routerTo(page) {
    router.push({ uri: `/pages/${page}` });
  },
  goBack() {
    goBackWithVibration();
  },
  loadDeviceInfo() {
    if (!this.showStorageWarning) { this.isStorageLow = false; return; }

    const now = Date.now();
    if (this.storageInfoLoaded && now - this.lastDeviceInfoTs < 30000) {
      return;
    }
    this.lastDeviceInfoTs = now;
    this.storageInfoLoaded = true;

    device.getInfo({
      success: (ret) => {
        device.getTotalStorage({
          success: (data) => {
            const totalStorage = data.totalStorage || 0;
            device.getAvailableStorage({
              success: (availData) => {
                const availableStorage = availData.availableStorage || 0;
                const storageInfo = calculateStorageInfo(totalStorage, availableStorage, ret.product);
                this.isStorageLow = isStorageLow(storageInfo.actualAvailable);
              }
            });
          }
        });
      }
    });
  }
};
</script>

<style>
.page {
  width: 212px;
  height: 520px;
  background-color: #000000;
}
.list {
  width: 212px;
  height: 520px;
  position: absolute;
  top: 0px;
  left: 0px;
  padding: 86px 12px;
}
.item {
  width: 100%;
  height: 92px;
  padding: 10px 18px;
  margin-bottom: 8px;
  background-color: #262626;
  border-radius: 26px;
  flex-direction: column;
  justify-content: space-around;
  align-items: flex-start;
}
.search-item {
	height: 72px;
	flex-direction: row;
	align-items: center;
	justify-content: flex-start;
	background-color: #1f1f1f;
}
.search-content {
	flex-direction: row;
	align-items: center;
	justify-content: flex-start;
	width: 100%;
}
.search-placeholder {
	font-size: 26px;
	line-height: 36px;
	color: rgba(255, 255, 255, 0.6);
}
.item-content {
  width: 100%;
  flex-direction: column;
  justify-content: space-around;
  align-items: flex-start;
  flex: 1;
  height: 100%;
  overflow: hidden;
}
.cover-item {
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
}
.cover-image {
  width: 52px;
  height: 70px;
  background-color: #333;
  margin-right: 12px;
  border-radius: 8px;
  flex-shrink: 0;
}
.cover-content {
  flex-direction: column;
  justify-content: space-around;
  align-items: flex-start;
  flex: 1;
  height: 100%;
  overflow: hidden;
}
.itemtext {
  font-size: 23px;
  width: 100%;
  font-weight: bold;
  color: white;
  text-overflow: ellipsis;
  lines: 1;
}
.itemtext2 {
  font-size: 20px;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.6);
  text-overflow: ellipsis;
  lines: 1;
}
.pagination-container {
  width: 100%;
  height: 72px;
  justify-content: center;
  align-items: center;
}
.pagination-controls {
  width: 100%;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding: 0 6px;
}
.pagination-button {
  width: 52px;
  height: 52px;
}
.pagination-text {
  font-size: 20px;
  font-weight: bold;
  color: white;
}
</style>
