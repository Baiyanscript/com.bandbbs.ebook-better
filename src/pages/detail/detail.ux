<template>
	<div class="page">
		<scroll
			id="scrollId"
			if="{{readMode !== 'nostalgic'}}"
			style="position: absolute; width: 212px; height: {{scrollHeight}}px; top: {{verticalMargin}}px;"
			scroll-y="{{true}}"
			scroll-top="{{scrollTopValue}}"
			@scroll="onScroll"
			@scrolltop="onScrollTop"
			@scrollbottom="onScrollBottom"
			@click="onTxtClick"
			onlongpress="onTxtLongPress"
			@touchstart="onTouchStart"
			@touchmove="onTouchMove"
			@touchend="onTouchEnd"
			bounces="{{(isAtChapterStart || isAtChapterEnd) && (chapterSwitchStyle == 'boundary')}}"
		>
			<div id="contentContainer" style="position: absolute; width:212px; flex-direction: column;">
				<div if="{{chapterSwitchStyle == 'button' && currentChapterIndexInAll > 0}}" style="width: 100%; height: {{chapterSwitchHeight}}px; justify-content: center; align-items: center; flex-direction: column;" @click="onPrevChapterClick">
					<text static style="color: #aaa; font-size: 20px; font-weight: bold;">上一章</text>
					<text if="{{chapterSwitchShowInfo && prevChapterName}}" style="color: #666; font-size: 14px; lines: 1; text-overflow: ellipsis; max-width: 80%;">{{prevChapterName}}</text>
				</div>
				<div style="flex-direction: column; width: 100%; padding-bottom: 20px;">
					<div if="{{chapterStartEmptyLines}}" style="height: 100px; width: 100%;"></div>
					<text if="{{chapterStartNumber}}" style="width: 212px; text-align: left; color: rgba(255,255,255,{{opacity/100}}); font-size: {{fontSize * 0.8}}px; font-weight: bold; margin-bottom: 10px;">第 {{currentChapterIndexInAll + 1}} / {{totalChapters}} 章</text>
					<text if="{{chapterStartName}}" style="width: 212px; text-align: left; color: rgba(255,255,255,{{opacity/100}}); font-size: {{fontSize * 1.2}}px; font-weight: bold; margin-bottom: 20px;">{{currentChapterName}}</text>
					<text if="{{chapterStartWordCount && page1 && page1.offset === 0}}" style="width: 212px; text-align: left; color: rgba(255,255,255,{{opacity/100}}); font-size: {{fontSize * 0.8}}px; font-weight: bold; margin-bottom: 20px;">本章 {{currentChapterWordCount}} 字</text>
					<text if="{{chapterStartWordCount && (!page1 || page1.offset !== 0)}}" style="width: 212px; text-align: center; color: rgba(255,255,255,{{opacity/100}}); font-size: {{fontSize * 0.8}}px; font-weight: bold; margin-bottom: 20px;">- 滑到顶部以加载上一段 -</text>
				</div>
				<div id="page1" style="flex-direction: column; width: 100%; flex-shrink: 0;">
					<div for="{{page1.blocks}}" style="width: 212px; flex-direction: column;">
						<text if="{{$item.type === 'text'}}" style="width: 212px; text-align: left; color: rgba(255,255,255,{{opacity/100}}); font-size: {{fontSize}}px; font-weight: {{boldEnabled ? 'bold' : 'normal'}}; line-height: {{lineHeight}}px;">{{$item.text}}</text>
						<div if="{{$item.type === 'illustration'}}" style="width: 176px; margin-left: 18px; margin-top: 12px; margin-bottom: 12px; padding-top: 10px; padding-bottom: 10px; padding-left: 12px; padding-right: 12px; background-color: rgba(43, 104, 214, 0.24); border-width: 2px; border-color: rgba(127, 186, 255, 0.88); border-radius: 16px; flex-direction: column; align-items: center;" @click="openIllustration($item)">
							<text static style="width: 80px; text-align: center; color: #9fd4ff; font-size: {{fontSize * 0.5}}px; font-weight: bold; line-height: {{lineHeight * 0.7}}px; background-color: rgba(159, 212, 255, 0.16); border-radius: 14px; padding-top: 3px; padding-bottom: 3px; margin-bottom: 8px;">插图</text>
							<text style="width: 100%; text-align: center; color: #f2f7ff; font-size: {{fontSize * 0.82}}px; font-weight: bold; line-height: {{lineHeight}}px;">{{$item.text}}</text>
							<text if="{{$item.altText}}" style="width: 100%; text-align: center; color: #b8c9e8; font-size: {{fontSize * 0.58}}px; line-height: {{lineHeight * 0.8}}px; margin-top: 6px;">{{$item.altText}}</text>
						</div>
					</div>
				</div>
				<div id="page2" if="{{page2}}" style="flex-direction: column; width: 100%; flex-shrink: 0;">
					<div for="{{page2.blocks}}" style="width: 212px; flex-direction: column;">
						<text if="{{$item.type === 'text'}}" style="width: 212px; text-align: left; color: rgba(255,255,255,{{opacity/100}}); font-size: {{fontSize}}px; font-weight: {{boldEnabled ? 'bold' : 'normal'}}; line-height: {{lineHeight}}px;">{{$item.text}}</text>
						<div if="{{$item.type === 'illustration'}}" style="width: 176px; margin-left: 18px; margin-top: 12px; margin-bottom: 12px; padding-top: 10px; padding-bottom: 10px; padding-left: 12px; padding-right: 12px; background-color: rgba(43, 104, 214, 0.24); border-width: 2px; border-color: rgba(127, 186, 255, 0.88); border-radius: 16px; flex-direction: column; align-items: center;" @click="openIllustration($item)">
							<text static style="width: 80px; text-align: center; color: #9fd4ff; font-size: {{fontSize * 0.5}}px; font-weight: bold; line-height: {{lineHeight * 0.7}}px; background-color: rgba(159, 212, 255, 0.16); border-radius: 14px; padding-top: 3px; padding-bottom: 3px; margin-bottom: 8px;">插图</text>
							<text style="width: 100%; text-align: center; color: #f2f7ff; font-size: {{fontSize * 0.82}}px; font-weight: bold; line-height: {{lineHeight}}px;">{{$item.text}}</text>
							<text if="{{$item.altText}}" style="width: 100%; text-align: center; color: #b8c9e8; font-size: {{fontSize * 0.58}}px; line-height: {{lineHeight * 0.8}}px; margin-top: 6px;">{{$item.altText}}</text>
						</div>
					</div>
				</div>
				<div if="{{chapterSwitchStyle == 'button' && isAtChapterEnd && currentChapterIndexInAll < totalChapters - 1}}" style="width: 100%; height: {{chapterSwitchHeight}}px; justify-content: center; align-items: center; flex-direction: column;" @click="onNextChapterClick">
					<text static style="color: #aaa; font-size: 20px; font-weight: bold;">下一章</text>
					<text if="{{chapterSwitchShowInfo && nextChapterName}}" style="color: #666; font-size: 14px; lines: 1; text-overflow: ellipsis; max-width: 80%;">{{nextChapterName}}</text>
				</div>
			</div>
		</scroll>

		<div if="{{readMode === 'nostalgic'}}" style="position: absolute; width: 212px; height: 520px; top: 0px;" @click="onNostalgicClick" @touchstart="onNostalgicTouchStart" @touchmove="onNostalgicTouchMove" @touchend="onNostalgicTouchEnd" onlongpress="onTxtLongPress">
			<div id="nostalgicContainer" style="position: absolute; width: 212px; height: {{pageHeigh}}px; top: {{nostalgicTop}}px; overflow: hidden; pointer-events: none;">
				<text if="{{nostalgicPageType !== 'illustration'}}" id="box1" style="lines: -1; width: 212px; text-align: left; color: rgba(255,255,255,{{opacity/100}}); font-size: {{fontSize}}px; font-weight: {{boldEnabled ? 'bold' : 'normal'}}; position: absolute; top: {{nostalgicOffsetTopNormal}}px; line-height: {{lineHeight}}px; left: 0px; pointer-events: none;">{{nostalgicText}}</text>
				<div if="{{nostalgicPageType === 'illustration'}}" style="width: 212px; height: {{pageHeigh}}px; align-items: center; justify-content: center; flex-direction: column; pointer-events: none;">
					<text static style="width: 80px; text-align: center; color: #9fd4ff; font-size: {{fontSize * 0.5}}px; font-weight: bold; line-height: {{lineHeight * 0.7}}px; background-color: rgba(159, 212, 255, 0.16); border-radius: 14px; padding-top: 3px; padding-bottom: 3px; margin-bottom: 12px;">插图</text>
					<img src="{{nostalgicIllustrationUri}}" style="width: 176px; height: {{pageHeigh - 80}}px; object-fit: contain; background-color: #000000;" />
					<text if="{{nostalgicIllustrationAlt}}" style="width: 160px; text-align: center; color: #b8c9e8; font-size: {{fontSize * 0.56}}px; line-height: {{lineHeight * 0.8}}px; margin-top: 10px;">{{nostalgicIllustrationAlt}}</text>
				</div>
			</div>
		</div>

		<img show="{{showSetting || (alwaysShowTime && !isNearTopForHd)}}" src="/common/images/hd.png" style="position: absolute;left: 0px;top: 0px;width: 212px;height: 142px;" />
		<div show="{{showSetting || (alwaysShowTime && !isNearTopForHd)}}" style="position: absolute; left: 60px; top: 8px; width: 92px; flex-direction: column; align-items: center;">
			<text if="{{showSetting || (alwaysShowBattery && alwaysShowTime && !isNearTopForHd)}}" style="line-height: 18px; font-weight: bold; font-size: 14px; color: rgba(255,255,255,0.6); text-align: center;">{{batteryLevel}}</text>
			<text style="line-height: 22px; font-weight: bold; font-size: 18px; color: rgba(255,255,255,0.6); text-align: center;">{{nowTime}}</text>
		</div>
		<div show="{{showSetting}}" style="position: absolute;left: 60px;top: 40px;width: 92px;height: 32px;justify-content: center; align-items: center;" @click="onTitleClick" onlongpress="onTitleLongPress">
			<marquee if="{{textReaderMarqueeEnabled}}" scrollamount="50" text-offset="25" style="width: 100%; height: 100%; line-height: 32px;font-weight:bold;font-size:20px;color:white;text-align:center;">{{currentChapterName}}</marquee>
			<text else style="width: 100%; height: 100%; line-height: 32px;font-weight:bold;font-size:20px;color:white;text-align:center;lines: 1;">{{currentChapterName}}</text>
		</div>
		<img show="{{showSetting}}" src="/common/images/bt.png" style="position: absolute;left: 0px;top: 378px;width: 212px;height: 142px;" />
		<div show="{{showSetting}}" style="position: absolute; top: 412px; left: 30px; width: 152px; height: 100px; flex-direction: column; justify-content: flex-start; align-items: center;">
			<marquee if="{{detailProgressMarqueeEnabled}}" scrollamount="40" text-offset="25" style="line-height: 32px;font-weight:bold;font-size:22px;color:white;text-align:center;">{{currentPage}} / {{totalPages}}</marquee>
			<text else style="line-height: 32px;font-weight:bold;font-size:22px;color:white;text-align:center;lines: 1;">{{currentPage}} / {{totalPages}}</text>
			<img src="/common/images/more.png" @click="onMoreClick" onlongpress="onMoreLongPress" style="width: 72px;height: 72px;margin-top: 2px;" />
		</div>
	</div>
</template>

<script>
import prompt from '@system.prompt'
import file from '@system.file'
import router from '@system.router'
import storage from '../../utils/storage.js'
import bookStorage from '../../utils/bookStorage.js'
import chapterManager from '../../utils/chapterManager.js'
import brightness from '@system.brightness'
import app from '@system.app'
import readingTimeStorage from '../../utils/readingTimeStorage.js'
import battery from '@system.battery'
import illustrationUtil from '../../utils/illustration.js'
import vibrator from '@system.vibrator'

export default {
	allSize: 0,
	autoInterval: null,
	cPath: "",
	private: {
		txtSizePage: 400,
		fontSize: 24,
		lineHeight: 34,
		pageHeigh: 520,
		verticalMargin: 20,
		scrollHeight: 520,
		showSetting: true,
		displayProgress: 0,
		loadingNext: false,
		loadingPrev: false,
		page1: { text: "加载中...", offset: 0, length: 0, blocks: [{ type: 'text', text: '加载中...' }] },
		page2: null,
		currentFileOffset: 0,
		opacity: 100,
		swipe: 'column',
		auto: false,
		nowTime: "00:00",
		batteryLevel: "",
		timer: null,
		timeCounter: 0,
		savedScrollOffset: 0,
		currentScrollTop: 0,
		totalPages: 0,
		currentPage: 0,
		isKeepScreenOn: false,
		keepScreenOnByAuto: false,
		currentChapterIndexInAll: 0,
		currentChapterName: "",
		isAtChapterEnd: false,
		isAtChapterStart: false,
		scrollTopValue: 0,
		wait: false,
		longPressTriggered: false,
		saveDataTimeout: null,
		totalChapters: 0,
		teacherScreenEnabled: false,
		clickCount: 0,
		clickTimeout: null,
		chapterProgress: 0,
		gestureMode: 'single',
		gestureClickCount: 0,
		gestureClickTimeout: null,
		chapterSwitchHeight: 80,
		chapterSwitchSensitivity: 50,
		swipeSensitivity: 80,
		chapterSwitchStyle: 'button',
		touchStartY: 0,
		overscrollDistance: 0,
		isTouching: false,
		touchStartX: 0,
		touchEndX: 0,
		nostalgicTouchStartX: 0,
		nostalgicTouchStartY: 0,
		nostalgicTouchEndX: 0,
		nostalgicTouchEndY: 0,
		nostalgicIsTouching: false,
		isInitialized: false,
		longPressTimeout: null,
		isProcessingClick: false,
		autoReadDistance: 100,
		timeFormat: '24h',
		contentHeight: 0,
		contentHeightCacheKey: '',
		preventParagraphSplitting: false,
		saveMode: 'exit',
		saveIntervalValue: 10,
		alwaysShowTime: false,
		alwaysShowTimeSensitivity: 50,
		alwaysShowBattery: true,
		isNearTopForHd: false,
		lastTxtSizePage: 400,
		lastFontSize: 24,
		lastIllustrationEnabled: true,
		readMode: 'scroll',
		nostalgicTop: 10,
		nostalgicOffsetTopNormal: 0,
		nostalgicOffsetTopPreview: 0,
		nostalgicPreViewShowFlag: false,
		nostalgicText: '',
		nostalgicTextPre: '',
		nostalgicBoxAllHeightNormal: 0,
		nostalgicBoxAllHeightPreview: 0,
		nostalgicSavedOffset: 0,
		nostalgicPageTurnMode: 'topBottomClick',
		textReaderMarqueeEnabled: false,
		detailProgressMarqueeEnabled: false,
		boldEnabled: true,
		illustrationEnabled: true,
		chapterStartEmptyLines: false,
		chapterStartNumber: false,
		chapterStartName: false,
		chapterStartWordCount: false,
		currentChapterWordCount: 0,
		chapterSwitchShowInfo: false,
		prevChapterName: '',
		nextChapterName: '',
		periodicSaveTimer: null,
		readingTimeSaveTimer: null,
		readingTimeRecording: false,
		shortcutLongPressScreenOn: false,
		shortcutDoubleClickBookmark: false,
		shortcutTripleClickBookmarkManager: false,
		titleClickCount: 0,
		titleClickTimeout: null,
		_shouldScrollToTop: false,
		_fromBookmark: false,
		_bookmarkOffsetInChapter: null,
		_bookmarkScrollOffset: null,
		_fromPercent: false,
		_percentOffsetInChapter: null,
		_percentTargetPercent: null,
		isChangingChapter: false,
		_scrollTimer: null,
		_scrollUpdateScheduled: false,
		_lastCalcTime: 0,
		loadingBookToken: 0,
		nostalgicHeightCacheKey: '',
		nostalgicCharsPerPage: 100,
		showSettingProgressPercentOnly: false,
		fontColorWithOpacity: 'rgba(255,255,255,1)',
		nostalgicPageType: 'text',
		nostalgicIllustrationUri: '',
		nostalgicIllustrationAlt: '',
		nostalgicPageEndOffset: 0,
		nostalgicPageHistory: [],
		// Feature 2: Teacher screen advanced
		teacherScreenAdvanced: false,
		proximitySubscription: null,
		proximityCoveredTime: 0,
		// Feature 3: Edge swipe
		edgeSwipeEnabled: false,
		edgeSwipeAction: 'bookmarks',
		edgeTouchStartX: 0,
		edgeTouchStartY: 0,
		edgeTouchActive: false,
		// Feature 4: Vibrate
		vibrateChapterSwitch: false,
		vibrateOnTouch: false,
		// Feature 6: Bookmark jump temp
		_originalReadingProgress: null,
		justReturnedFromBookmark: false,
		// Feature 7: Long press more
		moreLongPressTimer: null,
		moreLongPressTriggered: false,
		// UX enhancements
		uxBrightnessGesture: false,
		uxAutoSpeedControl: false,
		_currentBrightness: 128,
		_brightnessGestureActive: false,
		_brightnessGestureStartY: 0,
		_brightnessGestureStartValue: 128
	},
	protected: {
		name: '',
		chapterIndex: -1,
		chapterName: ''
	},

	updateStatus() {
		const date = new Date()
		let hours = date.getHours()
		let minutes = date.getMinutes()
		if (this.timeFormat === '12h') {
			let ampm = hours >= 12 ? '下午' : '上午'
			hours = hours % 12 || 12
			minutes = minutes < 10 ? '0' + minutes : minutes
			this.nowTime = `${ampm} ${hours}:${minutes}`
		} else {
			hours = hours < 10 ? '0' + hours : hours
			minutes = minutes < 10 ? '0' + minutes : minutes
			this.nowTime = `${hours}:${minutes}`
		}

		this.timeCounter++
		if (this.timeCounter >= 6 || this.batteryLevel === "") {
			this.timeCounter = 0
			battery.getStatus({
				success: (data) => {
					const level = Math.round(data.level * 100)
					this.batteryLevel = data.charging ? `充电中 ${level}%` : `电量 ${level}%`
				}
			})
		}
	},

	updatePageDisplay() {
		this.currentPage = this.currentChapterIndexInAll + 1
		this.totalPages = this.totalChapters
	},

	hexToRgba(hex, alpha) {
		const color = (hex || '').replace('#', '')
		if (color.length !== 6) return `rgba(255,255,255,${alpha})`
		const r = parseInt(color.substring(0, 2), 16)
		const g = parseInt(color.substring(2, 4), 16)
		const b = parseInt(color.substring(4, 6), 16)
		return `rgba(${r},${g},${b},${alpha})`
	},

	buildSegmentData(text, offset = 0, length = 0) {
		const safeText = text || ''
		return {
			text: illustrationUtil.toDisplayText(safeText, this.illustrationEnabled),
			offset,
			length,
			blocks: illustrationUtil.parseIllustrationBlocks(safeText, this.name, this.illustrationEnabled)
		}
	},

	openIllustration(block) {
		if (!block || !block.imageUri) return
		router.push({
			uri: 'pages/illustrationViewer',
			params: {
				pageTitle: block.altText || '插图',
				pageImageUri: block.imageUri
			}
		})
	},

	clearNostalgicHistory() {
		this.nostalgicPageHistory = []
	},

	captureNostalgicPageState() {
		return {
			type: this.nostalgicPageType,
			text: this.nostalgicText,
			offsetTop: this.nostalgicOffsetTopNormal,
			savedOffset: this.nostalgicSavedOffset,
			endOffset: this.nostalgicPageEndOffset,
			height: this.nostalgicBoxAllHeightNormal,
			imageUri: this.nostalgicIllustrationUri,
			altText: this.nostalgicIllustrationAlt
		}
	},

	applyNostalgicPage(page, readOffset, deferReset = false, afterApply = null) {
		this.nostalgicSavedOffset = readOffset
		this.nostalgicPageEndOffset = page.endOffset || readOffset
		this.nostalgicPageType = page.type || 'text'
		this.nostalgicText = page.text || ''
		this.nostalgicIllustrationUri = page.imageUri || ''
		this.nostalgicIllustrationAlt = page.altText || ''
		this.nostalgicHeightCacheKey = ''

		if (this.nostalgicPageType === 'illustration') {
			this.nostalgicOffsetTopNormal = 0
			this.nostalgicBoxAllHeightNormal = this.pageHeigh
			this.wait = false
			this.isChangingChapter = false
			if (afterApply) afterApply()
			this.updateNostalgicProgress()
			return
		}

		this.getNostalgicBoxHeight('box1', (h) => {
			this.nostalgicBoxAllHeightNormal = h
			this.wait = false
			this.isChangingChapter = false
			if (!deferReset) {
				this.resetNostalgicPageOffset()
			}
			if (afterApply) afterApply()
		})
	},

	resetTransientFlags() {
		this._shouldScrollToTop = false
		this._fromBookmark = false
		this._bookmarkOffsetInChapter = null
		this._bookmarkScrollOffset = null
		this._fromPercent = false
		this._percentOffsetInChapter = null
		this._percentTargetPercent = null
		this.loadingNext = false
		this.loadingPrev = false
		this.isChangingChapter = false
	},

	clearTimers() {
		if (this.periodicSaveTimer) { clearInterval(this.periodicSaveTimer); this.periodicSaveTimer = null }
		if (this.readingTimeSaveTimer) { clearInterval(this.readingTimeSaveTimer); this.readingTimeSaveTimer = null }
		if (this.autoInterval) { clearInterval(this.autoInterval); this.autoInterval = null }
		if (this.timer) { clearInterval(this.timer); this.timer = null }
		if (this.clickTimeout) { clearTimeout(this.clickTimeout); this.clickTimeout = null }
		if (this.gestureClickTimeout) { clearTimeout(this.gestureClickTimeout); this.gestureClickTimeout = null }
		if (this.longPressTimeout) { clearTimeout(this.longPressTimeout); this.longPressTimeout = null }
		if (this._scrollTimer) { clearTimeout(this._scrollTimer); this._scrollTimer = null }
		if (this.saveDataTimeout) { clearTimeout(this.saveDataTimeout); this.saveDataTimeout = null }
		this._scrollUpdateScheduled = false
	},

	estimateCharsPerLine() {
		return Math.max(1, Math.floor(212 / (this.fontSize * 0.6)))
	},

	estimateTextHeightByText(text) {
		if (!text) return 0
		const charsPerLine = this.estimateCharsPerLine()
		const lines = Math.ceil(text.length / charsPerLine)
		return Math.max(this.lineHeight, lines * this.lineHeight)
	},

	estimateScrollTopByOffset(offset) {
		const charsPerLine = this.estimateCharsPerLine()
		const charsBefore = Math.max(0, offset / 2)
		const lines = Math.ceil(charsBefore / charsPerLine)
		return Math.max(0, lines * this.lineHeight)
	},

	scheduleScrollUpdate() {
		if (this._scrollUpdateScheduled) return
		this._scrollUpdateScheduled = true
		setTimeout(() => {
			this._scrollUpdateScheduled = false
			this.calculateDisplayProgress()
			this.updateScrollDerivedFlags()
		}, 80)
	},

	getChapterEndTriggerThreshold() {
		let threshold = this.auto ? 40 : this.chapterSwitchSensitivity
		if (this.chapterSwitchStyle === 'button') {
			threshold += this.chapterSwitchHeight + 20
		}
		return threshold
	},

	getEffectiveContentHeightForChapterEnd() {
		let effectiveHeight = this.contentHeight || 0
		if (
			this.chapterSwitchStyle === 'button' &&
			this.isAtChapterEnd &&
			this.currentChapterIndexInAll < this.totalChapters - 1
		) {
			effectiveHeight = Math.max(0, effectiveHeight - this.chapterSwitchHeight)
		}
		return effectiveHeight
	},

	updateScrollDerivedFlags() {
		const isStart = this.currentFileOffset === 0 && this.currentScrollTop < 10
		if (this.isAtChapterStart !== isStart) this.isAtChapterStart = isStart

		const isNearTop = this.currentFileOffset === 0 && this.currentScrollTop < this.alwaysShowTimeSensitivity
		if (this.isNearTopForHd !== isNearTop) this.isNearTopForHd = isNearTop

		const lastSeg = this.page2 || this.page1
		const isLastSeg = lastSeg && (lastSeg.offset + lastSeg.length) >= this.allSize
		const effectiveContentHeight = this.getEffectiveContentHeightForChapterEnd()
		const isShortChapterAtEnd = isLastSeg && effectiveContentHeight > 0 && effectiveContentHeight <= this.scrollHeight
		if (isShortChapterAtEnd) {
			if (!this.isAtChapterEnd) this.isAtChapterEnd = true
		} else if (effectiveContentHeight > this.scrollHeight && isLastSeg) {
			const threshold = this.getChapterEndTriggerThreshold()
			const isNearBottom = this.currentScrollTop >= (effectiveContentHeight - this.scrollHeight - threshold)
			if (this.isAtChapterEnd !== isNearBottom) this.isAtChapterEnd = isNearBottom
		} else if (this.isAtChapterEnd) {
			this.isAtChapterEnd = false
		}
	},

	onInit() {
		this.updateStatus()
		this.timer = setInterval(() => { this.updateStatus() }, 10000)
		this.applyKeepScreenOnState()
		global.runGC()
	},

	async onShow() {
		if (!this.timer) {
			this.updateStatus()
			this.timer = setInterval(() => { this.updateStatus() }, 10000)
		}
		await this.loadSettings()

		const settingsChanged = this.isInitialized && (
			this.lastTxtSizePage !== this.txtSizePage ||
			this.lastFontSize !== this.fontSize ||
			this.lastIllustrationEnabled !== this.illustrationEnabled
		)

		if (typeof globalThis.isKeepScreenOn !== 'undefined') {
			const newKeepScreenOn = !!globalThis.isKeepScreenOn
			const keepScreenOnChanged = this.isKeepScreenOn !== newKeepScreenOn
			this.isKeepScreenOn = newKeepScreenOn
			this.applyKeepScreenOnState()
			if (keepScreenOnChanged) {
				prompt.showToast({ message: this.isKeepScreenOn ? '已开启屏幕常亮' : '已关闭屏幕常亮' })
			}
		} else {
			this.applyKeepScreenOnState()
		}

		this.applyKeepScreenOnState()

		storage.get({ key: 'EBOOK_TEACHER_SCREEN_ENABLED', success: (data) => { this.teacherScreenEnabled = data === 'true' } })

		// UX: Get current brightness for gesture
		if (this.uxBrightnessGesture) {
			try {
				brightness.getValue({ success: (data) => { this._currentBrightness = data.value || 128 } })
			} catch(e) {}
		}

		// Feature 2: Teacher screen advanced - proximity sensor
		if (this.teacherScreenAdvanced && this.isKeepScreenOn) {
			this.startProximitySensor()
		}

		// Feature 6: Handle return from bookmark jump
		if (globalThis._originalReadingProgress && this.justReturnedFromBookmark) {
			this.justReturnedFromBookmark = false
		}

		const isChapterJump = globalThis.justJumpedFromChapter || globalThis.justJumpedFromBookmark || globalThis.justJumpedFromPageNumber || globalThis.justJumpedFromPercent
		if (!this.isInitialized || isChapterJump || settingsChanged) {
			if (globalThis.justJumpedFromChapter) {
				this.chapterIndex = globalThis.newChapterIndex
				this.chapterName = globalThis.newChapterName
				delete globalThis.newChapterIndex
				delete globalThis.newChapterName
			}
			this.loadBook()
			this.isInitialized = true
			this.lastTxtSizePage = this.txtSizePage
			this.lastFontSize = this.fontSize
			this.lastIllustrationEnabled = this.illustrationEnabled
		}

		if (isChapterJump) this.showSetting = false

		if (this.readingTimeSaveTimer) {
			clearInterval(this.readingTimeSaveTimer)
			this.readingTimeSaveTimer = null
		}
		if (this.readingTimeRecording) {
			this.readingTimeSaveTimer = setInterval(async () => {
				if (this.name) {
					try { await readingTimeStorage.saveCurrentSession(this.name) } catch (e) {}
				}
			}, 5 * 60 * 1000)
		}

		this.setupAutoSave()

		if (this.auto && !this.autoInterval) {
			this.autoInterval = setInterval(() => {
				if (this.wait) return
				if (this.readMode === 'nostalgic') this.turnNostalgicPage(1)
				else if (this.isAtChapterEnd) this.changeChapter(1)
				else this.nextPage()
			}, this.auto * 1000)
		}
	},

	async loadSettings() {
		const keys = [
			'EBOOK_TXTSZPAGE', 'EBOOK_VERTICAL_MARGIN', 'EBOOK_FONT', 'EBOOK_OPACITY', 'EBOOK_SWIPE',
			'EBOOK_AUTO', 'EBOOK_GESTURE', 'EBOOK_CHAPTER_SWITCH_HEIGHT', 'EBOOK_CHAPTER_SWITCH_SENSITIVITY',
			'EBOOK_SWIPE_SENSITIVITY', 'EBOOK_CHAPTER_SWITCH_STYLE', 'EBOOK_AUTO_READ_DISTANCE', 'EBOOK_PREVENT_PARAGRAPH_SPLITTING',
			'EBOOK_TIME_FORMAT', 'EBOOK_PROGRESS_SAVE_MODE', 'EBOOK_PROGRESS_SAVE_INTERVAL',
			'EBOOK_ALWAYS_SHOW_TIME', 'EBOOK_ALWAYS_SHOW_TIME_SENSITIVITY', 'EBOOK_ALWAYS_SHOW_BATTERY', 'EBOOK_READ_MODE', 'EBOOK_READING_TIME_RECORDING',
			'EBOOK_TEXT_READER_MARQUEE_ENABLED', 'EBOOK_DETAIL_PROGRESS_MARQUEE_ENABLED', 'EBOOK_NOSTALGIC_PAGE_TURN_MODE',
			'EBOOK_BOLD_ENABLED', 'EBOOK_ILLUSTRATION_ENABLED', 'EBOOK_CHAPTER_START_EMPTY_LINES', 'EBOOK_CHAPTER_START_NUMBER', 'EBOOK_CHAPTER_START_NAME',
			'EBOOK_CHAPTER_START_WORD_COUNT', 'EBOOK_CHAPTER_SWITCH_SHOW_INFO', 'EBOOK_SHORTCUT_LONG_PRESS_SCREEN_ON',
			'EBOOK_SHORTCUT_DOUBLE_CLICK_BOOKMARK', 'EBOOK_SHORTCUT_TRIPLE_CLICK_BOOKMARK_MANAGER',
			'EBOOK_TEACHER_SCREEN_ADVANCED', 'EBOOK_EDGE_SWIPE_ENABLED', 'EBOOK_EDGE_SWIPE_ACTION',
			'EBOOK_VIBRATE_CHAPTER_SWITCH', 'EBOOK_VIBRATE_ON_TOUCH',
			'EBOOK_UX_BRIGHTNESS_GESTURE', 'EBOOK_UX_AUTO_SPEED_CONTROL'
		]
		const defaults = {
			'EBOOK_TXTSZPAGE': 400, 'EBOOK_VERTICAL_MARGIN': 20, 'EBOOK_FONT': 24, 'EBOOK_OPACITY': 100, 'EBOOK_SWIPE': 'column',
			'EBOOK_AUTO': null, 'EBOOK_GESTURE': 'single', 'EBOOK_CHAPTER_SWITCH_HEIGHT': 80, 'EBOOK_CHAPTER_SWITCH_SENSITIVITY': 50,
			'EBOOK_SWIPE_SENSITIVITY': 80, 'EBOOK_CHAPTER_SWITCH_STYLE': 'button', 'EBOOK_AUTO_READ_DISTANCE': 100, 'EBOOK_PREVENT_PARAGRAPH_SPLITTING': false,
			'EBOOK_TIME_FORMAT': '24h', 'EBOOK_PROGRESS_SAVE_MODE': 'exit', 'EBOOK_PROGRESS_SAVE_INTERVAL': 10,
			'EBOOK_ALWAYS_SHOW_TIME': false, 'EBOOK_ALWAYS_SHOW_TIME_SENSITIVITY': 200, 'EBOOK_ALWAYS_SHOW_BATTERY': true, 'EBOOK_READ_MODE': 'scroll', 'EBOOK_READING_TIME_RECORDING': false,
			'EBOOK_TEXT_READER_MARQUEE_ENABLED': false, 'EBOOK_DETAIL_PROGRESS_MARQUEE_ENABLED': false, 'EBOOK_NOSTALGIC_PAGE_TURN_MODE': 'topBottomClick',
			'EBOOK_BOLD_ENABLED': true, 'EBOOK_ILLUSTRATION_ENABLED': true, 'EBOOK_CHAPTER_START_EMPTY_LINES': false, 'EBOOK_CHAPTER_START_NUMBER': false, 'EBOOK_CHAPTER_START_NAME': false,
			'EBOOK_CHAPTER_START_WORD_COUNT': false, 'EBOOK_CHAPTER_SWITCH_SHOW_INFO': false, 'EBOOK_SHORTCUT_LONG_PRESS_SCREEN_ON': false,
			'EBOOK_SHORTCUT_DOUBLE_CLICK_BOOKMARK': false, 'EBOOK_SHORTCUT_TRIPLE_CLICK_BOOKMARK_MANAGER': false,
			'EBOOK_TEACHER_SCREEN_ADVANCED': false, 'EBOOK_EDGE_SWIPE_ENABLED': false, 'EBOOK_EDGE_SWIPE_ACTION': 'bookmarks',
			'EBOOK_VIBRATE_CHAPTER_SWITCH': false, 'EBOOK_VIBRATE_ON_TOUCH': false,
			'EBOOK_UX_BRIGHTNESS_GESTURE': false, 'EBOOK_UX_AUTO_SPEED_CONTROL': false
		}
		const mapping = {
			'EBOOK_TXTSZPAGE': 'txtSizePage', 'EBOOK_VERTICAL_MARGIN': 'verticalMargin', 'EBOOK_FONT': 'fontSize', 'EBOOK_OPACITY': 'opacity',
			'EBOOK_SWIPE': 'swipe', 'EBOOK_AUTO': 'auto', 'EBOOK_GESTURE': 'gestureMode', 'EBOOK_CHAPTER_SWITCH_HEIGHT': 'chapterSwitchHeight',
			'EBOOK_CHAPTER_SWITCH_SENSITIVITY': 'chapterSwitchSensitivity', 'EBOOK_SWIPE_SENSITIVITY': 'swipeSensitivity', 'EBOOK_CHAPTER_SWITCH_STYLE': 'chapterSwitchStyle',
			'EBOOK_AUTO_READ_DISTANCE': 'autoReadDistance', 'EBOOK_PREVENT_PARAGRAPH_SPLITTING': 'preventParagraphSplitting', 'EBOOK_TIME_FORMAT': 'timeFormat',
			'EBOOK_PROGRESS_SAVE_MODE': 'saveMode', 'EBOOK_PROGRESS_SAVE_INTERVAL': 'saveIntervalValue', 'EBOOK_ALWAYS_SHOW_TIME': 'alwaysShowTime',
			'EBOOK_ALWAYS_SHOW_TIME_SENSITIVITY': 'alwaysShowTimeSensitivity', 'EBOOK_ALWAYS_SHOW_BATTERY': 'alwaysShowBattery', 'EBOOK_READ_MODE': 'readMode', 'EBOOK_READING_TIME_RECORDING': 'readingTimeRecording',
			'EBOOK_TEXT_READER_MARQUEE_ENABLED': 'textReaderMarqueeEnabled', 'EBOOK_DETAIL_PROGRESS_MARQUEE_ENABLED': 'detailProgressMarqueeEnabled',
			'EBOOK_NOSTALGIC_PAGE_TURN_MODE': 'nostalgicPageTurnMode', 'EBOOK_BOLD_ENABLED': 'boldEnabled', 'EBOOK_ILLUSTRATION_ENABLED': 'illustrationEnabled', 'EBOOK_CHAPTER_START_EMPTY_LINES': 'chapterStartEmptyLines',
			'EBOOK_CHAPTER_START_NUMBER': 'chapterStartNumber', 'EBOOK_CHAPTER_START_NAME': 'chapterStartName', 'EBOOK_CHAPTER_START_WORD_COUNT': 'chapterStartWordCount',
			'EBOOK_CHAPTER_SWITCH_SHOW_INFO': 'chapterSwitchShowInfo', 'EBOOK_SHORTCUT_LONG_PRESS_SCREEN_ON': 'shortcutLongPressScreenOn',
			'EBOOK_SHORTCUT_DOUBLE_CLICK_BOOKMARK': 'shortcutDoubleClickBookmark', 'EBOOK_SHORTCUT_TRIPLE_CLICK_BOOKMARK_MANAGER': 'shortcutTripleClickBookmarkManager',
			'EBOOK_TEACHER_SCREEN_ADVANCED': 'teacherScreenAdvanced', 'EBOOK_EDGE_SWIPE_ENABLED': 'edgeSwipeEnabled',
			'EBOOK_EDGE_SWIPE_ACTION': 'edgeSwipeAction', 'EBOOK_VIBRATE_CHAPTER_SWITCH': 'vibrateChapterSwitch',
			'EBOOK_VIBRATE_ON_TOUCH': 'vibrateOnTouch',
			'EBOOK_UX_BRIGHTNESS_GESTURE': 'uxBrightnessGesture',
			'EBOOK_UX_AUTO_SPEED_CONTROL': 'uxAutoSpeedControl'
		}

		const promises = keys.map(key => new Promise(resolve => {
			storage.get({ key, success: data => resolve({ key, val: data }), fail: () => resolve({ key, val: null }) })
		}))
		const results = await Promise.all(promises)

		results.forEach(({ key, val }) => {
			const prop = mapping[key]
			const defaultValue = defaults[key]
			if (val === null || val === '') this[prop] = defaultValue
			else if (key === 'EBOOK_AUTO') {
				try {
					const parsed = typeof val === 'string' ? JSON.parse(val) : val
					if (parsed && parsed.enable) this.auto = parsed.speed
				} catch (e) {
					this.auto = false
				}
			} else if (typeof defaultValue === 'number') {
				this[prop] = parseInt(val)
			} else if (typeof defaultValue === 'boolean') {
				this[prop] = val === 'true' || val === true
			} else {
				this[prop] = val
			}
		})

		this.lineHeight = parseInt((-0.01) * (this.fontSize ** 2) + 1.62 * this.fontSize - 3.23)
		this.updateScrollHeight()

		if (this.readMode === 'nostalgic' && this.nostalgicText) {
			this.getNostalgicBoxHeight('box1', (h) => {
				this.nostalgicBoxAllHeightNormal = h
				this.resetNostalgicPageOffset()
			})
		}
	},

	setupAutoSave() {
		if (this.periodicSaveTimer) {
			clearInterval(this.periodicSaveTimer)
			this.periodicSaveTimer = null
		}
		if (this.saveMode === 'periodic' && this.saveIntervalValue > 0) {
			this.periodicSaveTimer = setInterval(() => { this._performSave() }, this.saveIntervalValue * 1000)
		}
	},

	updateContentHeight(force = false) {
		const cacheKey = [
			this.currentChapterIndexInAll,
			this.fontSize,
			this.lineHeight,
			this.txtSizePage,
			this.page1 ? this.page1.offset : -1,
			this.page1 ? this.page1.length : -1,
			this.page2 ? this.page2.offset : -1,
			this.page2 ? this.page2.length : -1,
			this.readMode
		].join('|')

		if (!force && this.contentHeightCacheKey === cacheKey && this.contentHeight > 0) return
		this.contentHeightCacheKey = cacheKey

		setTimeout(() => {
			const el = this.$element("contentContainer")
			if (!el) return
			el.getBoundingClientRect({
				success: (rect) => {
					this.contentHeight = rect.height
					this.updateScrollDerivedFlags()
				}
			})
		}, 50)
	},

	updateScrollHeight() {
		this.scrollHeight = 520 - this.verticalMargin * 2
		this.pageHeigh = Math.floor(this.scrollHeight / this.lineHeight) * this.lineHeight
		this.nostalgicTop = this.verticalMargin + Math.floor((this.scrollHeight - this.pageHeigh) / 2)
		this.calculateNostalgicCharsPerPage()
	},

	calculateDisplayProgress() {
		if (!this.showProgressBar) {
			this.displayProgress = 0
			return
		}
		if (this.isAtChapterEnd) {
			this.displayProgress = 100
			return
		}

		let prog = 0
		if (this.readMode === 'nostalgic') {
			if (this.allSize > 0) {
				const READ_LEN = this.txtSizePage * 2
				const bytesPerPixel = READ_LEN / (this.nostalgicBoxAllHeightNormal || 1)
				const scrolled = this.nostalgicSavedOffset + (this.nostalgicOffsetTopNormal < 0 ? -this.nostalgicOffsetTopNormal * bytesPerPixel : 0)
				prog = (scrolled / this.allSize) * 100
			}
		} else {
			if (this.allSize > 0) {
				let totalScrolled = this.currentFileOffset
				if (this.contentHeight > 0) {
					const bytesPerPixel = (this.page1.length + (this.page2 ? this.page2.length : 0)) / this.contentHeight
					totalScrolled += this.currentScrollTop * bytesPerPixel
				}
				prog = (totalScrolled / this.allSize) * 100
			}
		}

		this.displayProgress = Math.min(100, Math.max(0, prog))
	},

	encodeUtf16LEBuffer(buffer, bytesToUse) {
		const chars = []
		for (let i = 0; i < bytesToUse; i += 2) {
			chars.push(String.fromCharCode(buffer[i + 1] * 256 + buffer[i]))
		}
		return chars.join('')
	},

	calculateNostalgicCharsPerPage() {
		if (this.scrollHeight <= 0 || this.lineHeight <= 0 || this.fontSize <= 0) {
			this.nostalgicCharsPerPage = 100
			return
		}
		const linesPerPage = Math.floor(this.scrollHeight / this.lineHeight)
		const charsPerLine = Math.floor(212 / this.fontSize)
		if (linesPerPage <= 0 || charsPerLine <= 0) {
			this.nostalgicCharsPerPage = 100
			return
		}
		this.nostalgicCharsPerPage = Math.min(10000, linesPerPage * charsPerLine)
	},

	async loadBook() {
		const token = ++this.loadingBookToken
		this.resetTransientFlags()

		try {
			const version = await chapterManager.checkVersion(this.name)
			if (token !== this.loadingBookToken) return
			if (version === 'old') return await chapterManager.handleOldVersion(this.name)
			if (version === 'none') {
				this.page1 = this.buildSegmentData("本书没有内容", 0, 0)
				this.page2 = null
				this.totalChapters = 0
				this.updatePageDisplay()
				return
			}
			this.totalChapters = await chapterManager.getTotalChapters(this.name)
		} catch (e) {
			prompt.showToast({ message: '章节列表加载失败' })
			this.totalChapters = 0
			return
		}

		if (token !== this.loadingBookToken) return

		if (this.totalChapters === 0) {
			this.page1 = this.buildSegmentData("本书没有内容", 0, 0)
			this.page2 = null
			this.updatePageDisplay()
			return
		}

		let progress = await bookStorage.get(this.name)
		if (!progress) progress = {}

		let chapterToLoadIndex = 0
		let offsetInChapter = 0
		let scrollOffset = 0
		let shouldScrollToTop = false

		if (globalThis.justJumpedFromChapter) {
			chapterToLoadIndex = this.chapterIndex
			this.chapterName = this.chapterName || globalThis.newChapterName || ''
			shouldScrollToTop = true
			globalThis.justJumpedFromChapter = false
		} else if (globalThis.justJumpedFromPageNumber) {
			chapterToLoadIndex = globalThis.justJumpedChapterIndex !== undefined ? globalThis.justJumpedChapterIndex : (progress.chapterIndex || 0)
			shouldScrollToTop = true
			globalThis.justJumpedFromPageNumber = false
			delete globalThis.justJumpedChapterIndex
		} else if (globalThis.justJumpedFromPercent) {
			this._fromPercent = true
			chapterToLoadIndex = globalThis.justJumpedChapterIndex !== undefined ? globalThis.justJumpedChapterIndex : (progress.chapterIndex || 0)
			offsetInChapter = globalThis.justJumpedOffsetInChapter || 0
			this._percentOffsetInChapter = offsetInChapter
			this._percentTargetPercent = globalThis.justJumpedTargetPercent
			globalThis.justJumpedFromPercent = false
			delete globalThis.justJumpedChapterIndex
			delete globalThis.justJumpedOffsetInChapter
			delete globalThis.justJumpedTargetPercent
		} else if (globalThis.justJumpedFromBookmark) {
			chapterToLoadIndex = globalThis.justJumpedBookmarkChapterIndex !== undefined ? globalThis.justJumpedBookmarkChapterIndex : (progress.chapterIndex || 0)
			offsetInChapter = progress.offsetInChapter || 0
			scrollOffset = progress.scrollOffset || 0
			this._fromBookmark = true
			this._bookmarkOffsetInChapter = offsetInChapter
			this._bookmarkScrollOffset = scrollOffset
			globalThis.justJumpedFromBookmark = false
			delete globalThis.justJumpedBookmarkChapterIndex
		} else if (progress.chapterIndex !== null && progress.chapterIndex !== undefined) {
			chapterToLoadIndex = progress.chapterIndex
			offsetInChapter = progress.offsetInChapter || 0
			scrollOffset = progress.scrollOffset || 0
		}

		if (chapterToLoadIndex === null || chapterToLoadIndex === undefined) {
			const available = await chapterManager.getAllAvailableChapters(this.name)
			if (available.length > 0) chapterToLoadIndex = available[0].index
			else {
				this.page1 = this.buildSegmentData("本书没有内容", 0, 0)
				this.page2 = null
				return
			}
		}

		const oldTxtSizePage = progress.txtSizePage || this.txtSizePage
		const oldFontSize = progress.fontSize || this.fontSize
		if (oldTxtSizePage !== this.txtSizePage || oldFontSize !== this.fontSize) {
			const fontSizeRatio = oldFontSize > 0 ? this.fontSize / oldFontSize : 1
			const txtSizePageRatio = oldTxtSizePage > 0 ? this.txtSizePage / oldTxtSizePage : 1
			if (txtSizePageRatio !== 1 && offsetInChapter > 0) offsetInChapter = Math.floor(offsetInChapter * txtSizePageRatio)
			if (fontSizeRatio !== 1 && scrollOffset > 0) scrollOffset = Math.floor(scrollOffset * fontSizeRatio)
		}

		if (chapterToLoadIndex < 0 || chapterToLoadIndex >= this.totalChapters) chapterToLoadIndex = 0
		this.currentFileOffset = offsetInChapter
		this.savedScrollOffset = scrollOffset
		this.scrollTopValue = scrollOffset
		this.currentScrollTop = scrollOffset
		this._shouldScrollToTop = shouldScrollToTop

		this.loadChapter(chapterToLoadIndex, () => {
				if (token !== this.loadingBookToken) return
		if (this.readMode === 'nostalgic') {
				this.wait = false
				this.loadNostalgicChapter(offsetInChapter)
			} else {
				this.loadInitialSegments()
				this.isAtChapterStart = shouldScrollToTop || (this.currentFileOffset === 0 && this.savedScrollOffset < 10)
				this.isNearTopForHd = this.currentFileOffset === 0 && this.savedScrollOffset < this.alwaysShowTimeSensitivity
			}
			this.startReadingTimeRecording()
		})
	},

	startReadingTimeRecording() {
		if (!this.readingTimeRecording || !this.name || this.totalChapters === 0) return
		try { readingTimeStorage.recordReadingStart(this.name) } catch (e) {}
	},

	async loadChapter(chapterIdxInAll, callback) {
		if (chapterIdxInAll < 0 || chapterIdxInAll >= this.totalChapters) { if (callback) callback(); return }
		const chapter = await chapterManager.getChapterByIndex(this.name, chapterIdxInAll)
		if (!chapter) {
			prompt.showToast({ message: '无法加载章节信息' })
			if (callback) callback()
			return
		}

		this.page1 = this.buildSegmentData("", 0, 0)
		this.page2 = null
		this.isAtChapterStart = false
		this.isAtChapterEnd = false
		this.currentChapterIndexInAll = chapterIdxInAll
		this.currentChapterName = chapter.name
		this.currentChapterWordCount = chapter.wordCount || 0
		this.updatePageDisplay()
		this.cPath = `internal://files/books/${this.name}/content/${chapter.index}.txt`

		if (this.chapterSwitchShowInfo) {
			const prev = chapterIdxInAll > 0 ? await chapterManager.getChapterByIndex(this.name, chapterIdxInAll - 1) : null
			this.prevChapterName = prev ? prev.name : ''
			const next = chapterIdxInAll < this.totalChapters - 1 ? await chapterManager.getChapterByIndex(this.name, chapterIdxInAll + 1) : null
			this.nextChapterName = next ? next.name : ''
		}

		file.get({
			uri: this.cPath,
			success: (data) => {
				this.allSize = data.length
				if (callback) callback()
			},
			fail: (d, code) => {
				this.allSize = 0
				prompt.showToast({ message: code === 301 ? '文件不存在，请重新同步该章节' : `加载章节失败: ${code}` })
				if (callback) callback()
			}
		})
	},

	loadInitialSegments() {
		this.wait = true
		this.readFileText(this.currentFileOffset, (str, bytesRead) => {
			this.page1 = this.buildSegmentData(str, this.currentFileOffset, bytesRead)
			this.loadNextSegmentNoScroll()
			this.updateContentHeight()
		})
	},

	loadNextSegmentNoScroll() {
		const newOffset = this.page1.offset + this.page1.length
		if (newOffset >= this.allSize) {
			this.isAtChapterEnd = true
			this.page2 = null
			this.restoreScrollPosition()
			return
		}
		this.readFileText(newOffset, (str, bytesRead) => {
			this.page2 = str ? this.buildSegmentData(str, newOffset, bytesRead) : null
			this.restoreScrollPosition()
			this.updateContentHeight()
		})
	},

	restoreScrollPosition() {
		setTimeout(() => {
			if (this._shouldScrollToTop || (this.currentFileOffset === 0 && this.savedScrollOffset === 0)) {
				this.scrollTopValue = 0
				this.currentScrollTop = 0
				this.currentFileOffset = 0
				this.savedScrollOffset = 0
				this.finalizeScrollRestore()
				return
			}

			const targetOffset = (this._fromBookmark && this._bookmarkOffsetInChapter > 0) ? this._bookmarkOffsetInChapter :
				(this._fromPercent && this._percentOffsetInChapter > 0) ? this._percentOffsetInChapter : null

			const restore = (top) => {
				this.scrollTopValue = Math.max(0, Math.floor(top))
				this.currentScrollTop = Math.max(0, Math.floor(top))
				this.finalizeScrollRestore()
			}

			if (targetOffset !== null && targetOffset > 0) {
				this.$element("page1").getBoundingClientRect({
					success: (page1Rect) => {
						const p1Start = this.page1.offset
						const p1End = p1Start + this.page1.length

						if (this._fromPercent && this._percentTargetPercent !== null && this._percentTargetPercent !== undefined && this.allSize > 0) {
							const targetPercentOffset = Math.floor((this._percentTargetPercent / 100) * this.allSize)
							const charsPerLine = Math.max(1, Math.floor(212 / this.fontSize))

							if (targetPercentOffset >= p1Start && targetPercentOffset < p1End) {
								const charsIn = (targetPercentOffset - p1Start) / 2
								const lines = Math.ceil(charsIn / charsPerLine)
								restore(lines * this.lineHeight)
							} else if (targetPercentOffset < p1Start) {
								restore(0)
							} else {
								const charsBefore = targetPercentOffset / 2
								const lines = Math.ceil(charsBefore / charsPerLine)
								const estimatedScroll = lines * this.lineHeight

								if (this.page2 && this.page2.offset <= targetPercentOffset) {
									this.$element("page2").getBoundingClientRect({
										success: () => {
											const p2Start = this.page2.offset
											if (targetPercentOffset >= p2Start && targetPercentOffset < p2Start + this.page2.length) {
												const charsIn = (targetPercentOffset - p2Start) / 2
												const linesInP2 = Math.ceil(charsIn / charsPerLine)
												restore(page1Rect.height + linesInP2 * this.lineHeight)
											} else {
												restore(estimatedScroll)
											}
										},
										fail: () => restore(estimatedScroll)
									})
								} else {
									restore(estimatedScroll)
								}
							}
						} else if (targetOffset >= p1Start && targetOffset < p1End) {
							const charsIn = (targetOffset - p1Start) / 2
							const lines = Math.ceil(charsIn / Math.max(1, Math.floor(212 / (this.fontSize * 0.6))))
							restore((lines * this.lineHeight) + Math.max(0, this.savedScrollOffset))
						} else if (targetOffset < p1Start) {
							restore(Math.max(0, this.savedScrollOffset))
						} else {
							const charsBefore = targetOffset / 2
							const lines = Math.ceil(charsBefore / Math.max(1, Math.floor(212 / (this.fontSize * 0.6))))
							restore((lines * this.lineHeight) + Math.max(0, this.savedScrollOffset))
						}
					},
					fail: () => restore(Math.max(0, this.savedScrollOffset))
				})
			} else {
				restore(Math.max(0, this.savedScrollOffset))
			}
		}, 100)
	},

	finalizeScrollRestore() {
		const timeoutId = setTimeout(() => {
			this.wait = false
			this.isChangingChapter = false
		}, 500)

		const contentEl = this.$element("contentContainer")
		if (!contentEl) {
			clearTimeout(timeoutId)
			this.wait = false
			this.isChangingChapter = false
			this._shouldScrollToTop = false
			this._fromBookmark = false
			this._bookmarkOffsetInChapter = null
			this._bookmarkScrollOffset = null
			this._fromPercent = false
			this._percentOffsetInChapter = null
			this._percentTargetPercent = null
			return
		}

		contentEl.getBoundingClientRect({
			success: (rect) => {
				clearTimeout(timeoutId)
				this.contentHeight = rect.height
				this.wait = false
				this.isChangingChapter = false
				this._shouldScrollToTop = false
				this._fromBookmark = false
				this._bookmarkOffsetInChapter = null
				this._bookmarkScrollOffset = null
				this._fromPercent = false
				this._percentOffsetInChapter = null
				this._percentTargetPercent = null
				this.saveData(true)
			},
			fail: () => {
				clearTimeout(timeoutId)
				this.wait = false
				this.isChangingChapter = false
				this._shouldScrollToTop = false
				this._fromBookmark = false
				this._bookmarkOffsetInChapter = null
				this._bookmarkScrollOffset = null
				this._fromPercent = false
				this._percentOffsetInChapter = null
				this._percentTargetPercent = null
			}
		})
	},

	readFileText(readOffset, cb) {
		if (readOffset >= this.allSize) { cb('', 0); return }

		let length = this.txtSizePage * 2
		if (readOffset < 0) { length += readOffset; readOffset = 0 }
		const maxLength = this.allSize - readOffset
		if (length > maxLength) length = maxLength

		const self = this
		function attemptRead(len, attemptsLeft) {
			file.readArrayBuffer({
				uri: self.cPath, position: readOffset, length: len,
				success: (data) => {
					if (!data.buffer || data.buffer.byteLength === 0) { cb('', 0); return }
					try {
						const buffer = new Uint8Array(data.buffer)
						let bytesToUse = buffer.length

						if (self.preventParagraphSplitting && (readOffset + buffer.length) < self.allSize) {
							let lastNewlinePos = -1
							for (let i = buffer.length - 2; i >= 0; i -= 2) {
								const charCode = buffer[i + 1] * 256 + buffer[i]
								if (charCode === 10) {
									lastNewlinePos = i
									break
								}
							}
							if (lastNewlinePos >= 0) bytesToUse = lastNewlinePos + 2
						}

						let str2 = self.encodeUtf16LEBuffer(buffer, bytesToUse)
						const markerStart2 = str2.lastIndexOf('[[SINE_IMG|')
						if (markerStart2 >= 0 && str2.indexOf(']]', markerStart2) === -1) {
							str2 = str2.slice(0, markerStart2)
							bytesToUse = str2.length * 2
						}
						cb(str2, bytesToUse)
					} catch (e) { cb('', 0) }
				},
				fail: () => {
					if (attemptsLeft > 0) attemptRead(Math.max(256, Math.floor(len / 2)), attemptsLeft - 1)
					else cb('', 0)
				}
			})
		}
		attemptRead(length, 3)
	},

	onScroll(e) {
		if (this.wait) return
		this.currentScrollTop = e.scrollY
		this.scrollTopValue = e.scrollY
		this.savedScrollOffset = e.scrollY
		this.scheduleScrollUpdate()

		const lastSeg = this.page2 || this.page1
		const isLastSeg = lastSeg && (lastSeg.offset + lastSeg.length) >= this.allSize
		const effectiveContentHeight = this.getEffectiveContentHeightForChapterEnd()
		const isShortChapterAtEnd = isLastSeg && effectiveContentHeight > 0 && effectiveContentHeight <= this.scrollHeight
		if (isShortChapterAtEnd) {
			if (!this.isAtChapterEnd) this.isAtChapterEnd = true
		} else if (effectiveContentHeight > this.scrollHeight && isLastSeg) {
			const threshold = this.getChapterEndTriggerThreshold()
			const endTriggerTop = effectiveContentHeight - this.scrollHeight - threshold
			const isNearBottom = this.currentScrollTop >= endTriggerTop
			if (this.isAtChapterEnd !== isNearBottom) this.isAtChapterEnd = isNearBottom
		} else if (this.isAtChapterEnd) {
			this.isAtChapterEnd = false
		}
	},

	onScrollTop() {
		if (this.wait || this.currentFileOffset <= 0 || this.loadingPrev) return
		this.loadingPrev = true
		this.loadPrevSegment()
	},

	onScrollBottom() {
		if (this.wait || this.loadingNext) return
		this.loadingNext = true
		this.loadNextSegment()
	},

	loadNextSegment() {
		this.wait = true
		const lastSeg = this.page2 || this.page1
		const newOffset = lastSeg.offset + lastSeg.length
		if (newOffset >= this.allSize) {
			this.loadingNext = false
			this.isAtChapterEnd = true
			this.wait = false
			return
		}
		this.readFileText(newOffset, (str, bytesRead) => {
			this.loadingNext = false
			if (str) {
				setTimeout(() => {
					this.shiftPagesForward(this.buildSegmentData(str, newOffset, bytesRead))
				}, 30)
			} else {
				this.wait = false
			}
		})
	},

	shiftPagesForward(nextPageData) {
		const scrollPosBeforeLoad = this.currentScrollTop
		const page1El = this.$element("page1")

		const applyShift = (removeHeight) => {
			this.page1 = this.page2
			this.page2 = nextPageData
			const safeRemoveHeight = Math.max(0, Math.floor(removeHeight || 0))
			const newScrollPos = Math.max(0, scrollPosBeforeLoad - safeRemoveHeight)
			this.scrollTopValue = newScrollPos
			this.currentScrollTop = newScrollPos
			this.savedScrollOffset = newScrollPos
			this.currentFileOffset = this.page1.offset
			this.calculateDisplayProgress()
			this.saveData(true)
			this.wait = false
			this.updateContentHeight(true)
		}

		if (!page1El) {
			const estimatedHeight = this.estimateTextHeightByText(this.page1 ? this.page1.text : '')
			applyShift(estimatedHeight)
			return
		}

		page1El.getBoundingClientRect({
			success: (rect) => applyShift(rect.height),
			fail: () => {
				const estimatedHeight = this.estimateTextHeightByText(this.page1 ? this.page1.text : '')
				applyShift(estimatedHeight)
			}
		})
	},

	loadPrevSegment() {
		this.wait = true
		if (this.page1.offset <= 0) {
			this.wait = false
			this.loadingPrev = false
			return
		}
		const oldPage1 = this.page1
		const newOffset = Math.max(0, this.page1.offset - this.txtSizePage * 2)
		this.readFileText(newOffset, (str, bytesRead) => {
			this.loadingPrev = false
			if (str) {
				const prevPageData = this.buildSegmentData(str, newOffset, bytesRead)
				const applyShift = (addHeight) => {
					this.page2 = oldPage1
					this.page1 = prevPageData
					const safeAddHeight = Math.max(0, Math.floor(addHeight || 0))
					const newScrollPos = Math.max(0, this.currentScrollTop + safeAddHeight)
					this.scrollTopValue = newScrollPos
					this.currentScrollTop = newScrollPos
					this.savedScrollOffset = newScrollPos
					this.currentFileOffset = this.page1.offset
					this.calculateDisplayProgress()
					this.saveData(true)
					this.wait = false
					this.updateContentHeight(true)
				}

				const oldPage1El = this.$element("page1")
				if (!oldPage1El) {
					const estimatedHeight = this.estimateTextHeightByText(oldPage1 ? oldPage1.text : '')
					applyShift(estimatedHeight)
					return
				}

				oldPage1El.getBoundingClientRect({
					success: (rect) => applyShift(rect.height),
					fail: () => {
						const estimatedHeight = this.estimateTextHeightByText(oldPage1 ? oldPage1.text : '')
						applyShift(estimatedHeight)
					}
				})
			} else {
				this.wait = false
			}
		})
	},

	onTouchStart(e) {
		this.isTouching = true
		this.touchStartY = e.touches[0].clientY
		this.overscrollDistance = 0
		if (this.chapterSwitchStyle === 'swipe') {
			this.touchStartX = e.touches[0].clientX
			this.touchEndX = e.touches[0].clientX
		}
		// Feature 3: Edge swipe detection
		if (this.edgeSwipeEnabled) {
			const touch = e.touches[0]
			if (touch.clientX >= 182) {
				this.edgeTouchActive = true
				this.edgeTouchStartX = touch.clientX
				this.edgeTouchStartY = touch.clientY
			}
		}
		// UX: Left edge brightness gesture
		if (this.uxBrightnessGesture) {
			const touch = e.touches[0]
			if (touch.clientX <= 30) {
				this._brightnessGestureActive = true
				this._brightnessGestureStartY = touch.clientY
				this._brightnessGestureStartValue = this._currentBrightness || 128
			}
		}
	},

	onTouchMove(e) {
		if (!this.isTouching) return
		// UX: Brightness gesture move
		if (this._brightnessGestureActive && this.uxBrightnessGesture) {
			const deltaY = this._brightnessGestureStartY - e.touches[0].clientY
			const brightnessDelta = Math.floor(deltaY * 0.5)
			let newValue = Math.max(20, Math.min(255, this._brightnessGestureStartValue + brightnessDelta))
			this._currentBrightness = newValue
			try { brightness.setValue({ value: newValue }) } catch(ex) {}
			return
		}
		if (this.chapterSwitchStyle === 'boundary') {
			const deltaY = e.touches[0].clientY - this.touchStartY
			if (this.isAtChapterStart && deltaY > 0) this.overscrollDistance = deltaY
			else if (this.isAtChapterEnd && deltaY < 0) this.overscrollDistance = -deltaY
			else this.overscrollDistance = 0
		} else if (this.chapterSwitchStyle === 'swipe') {
			this.touchEndX = e.touches[0].clientX
		}
	},

	onTouchEnd(e) {
		if (!this.isTouching) return
		this.isTouching = false
		// UX: Brightness gesture end
		if (this._brightnessGestureActive) {
			this._brightnessGestureActive = false
			if (this._currentBrightness) {
				storage.set({ key: 'EBOOK_BRIGHTNESS', value: this._currentBrightness.toString() })
				storage.set({ key: 'EBOOK_BRIGHTNESS_FOLLOW_SYSTEM', value: 'false' })
				brightness.setMode({ mode: 0 })
			}
			return
		}
		// Feature 3: Edge swipe end
		if (this.edgeTouchActive) {
			this.edgeTouchActive = false
			const touch = e.changedTouches[0]
			const deltaX = touch.clientX - this.edgeTouchStartX
			if (deltaX < -50) {
				this.triggerEdgeSwipeAction()
				return
			}
		}
		if (this.chapterSwitchStyle === 'boundary') {
			if (this.overscrollDistance > this.chapterSwitchSensitivity) {
				if (this.isAtChapterStart) this.changeChapter(-1)
				else if (this.isAtChapterEnd) this.changeChapter(1)
			}
			this.overscrollDistance = 0
		} else if (this.chapterSwitchStyle === 'swipe' && this.touchStartX !== 0) {
			const deltaX = this.touchEndX - this.touchStartX
			if (Math.abs(deltaX) > this.swipeSensitivity) this.changeChapter(deltaX > 0 ? -1 : 1)
			this.touchStartX = 0
		}
	},

	onPrevChapterClick() { this.changeChapter(-1) },
	onNextChapterClick() { this.changeChapter(1) },

	changeChapter(offset) {
		if (this.wait) return
		this.wait = true
		this.isChangingChapter = true
		const nextIndex = this.currentChapterIndexInAll + offset

		if (nextIndex < 0) {
			prompt.showToast({ message: '已是第一章' })
			this.wait = false
			this.isChangingChapter = false
			return
		}
		if (nextIndex >= this.totalChapters) {
			prompt.showToast({ message: '已是最后一章' })
			if (this.autoInterval) {
				clearInterval(this.autoInterval)
				this.autoInterval = null
				prompt.showToast({ message: '已关闭自动翻页' })
				if (this.keepScreenOnByAuto) {
					this.keepScreenOnByAuto = false
					this.isKeepScreenOn = false
					brightness.setKeepScreenOn({ keepScreenOn: false })
				}
			}
			this.wait = false
			this.isChangingChapter = false
			return
		}
		global.runGC()
		this.vibrateOnChapterSwitch()
		this.isAtChapterEnd = false
		this.currentFileOffset = 0
		this.savedScrollOffset = 0
		this.scrollTopValue = 0
		this.currentScrollTop = 0

		this.loadChapter(nextIndex, () => {
			if (this.readMode === 'nostalgic') {
				this.loadNostalgicChapter(offset > 0 ? 0 : -1)
				this.isChangingChapter = false
			} else {
				this.page1 = this.buildSegmentData("加载中...", 0, 0)
				this.page2 = null
				if (offset > 0) {
					this.loadInitialSegments()
					this.isAtChapterStart = false
					this.isNearTopForHd = true
				} else {
					this.loadEndAndScroll()
					this.isAtChapterStart = false
					this.isNearTopForHd = false
				}
			}
			this.chapterProgress = offset > 0 ? 0 : 100
			this.saveData(true)
		})
	},

	loadEndAndScroll() {
		this.wait = true
		const readSize = this.txtSizePage * 3
		const readOffset = Math.max(0, this.allSize - readSize)
		this.currentFileOffset = readOffset

		this.readFileText(readOffset, (str, bytesRead) => {
			if (this.page1) this.page1.text = null
			if (this.page2) this.page2.text = null
			this.page2 = null
			this.page1 = this.buildSegmentData(str, readOffset, bytesRead)
			this.isAtChapterStart = (readOffset === 0)

			if ((readOffset + bytesRead) >= this.allSize) {
				this.isAtChapterEnd = true
				this.scrollToBottom()
			} else {
				this.loadUntilEnd(() => {
					this.isAtChapterEnd = true
					this.scrollToBottom()
				})
			}
		})
	},

	loadUntilEnd(callback) {
		const lastSeg = this.page2 || this.page1
		const newOffset = lastSeg.offset + lastSeg.length
		if (newOffset >= this.allSize) {
			if (callback) callback()
			return
		}
		this.readFileText(newOffset, (str, bytesRead) => {
			if (str) {
				this.page2 = this.buildSegmentData(str, newOffset, bytesRead)
				this.updateContentHeight()
				if ((newOffset + bytesRead) >= this.allSize) {
					if (callback) callback()
				} else {
					this.loadUntilEnd(callback)
				}
			} else {
				if (callback) callback()
			}
		})
	},

	scrollToBottom() {
		this.updateContentHeight()
		setTimeout(() => {
			const el = this.$element("contentContainer")
			if (!el) {
				this.wait = false
				this.isChangingChapter = false
				return
			}
			el.getBoundingClientRect({
				success: (rect) => {
					this.contentHeight = rect.height
					const maxScrollPos = Math.max(0, this.contentHeight - this.scrollHeight)
					this.scrollTopValue = maxScrollPos
					this.currentScrollTop = maxScrollPos
					this.savedScrollOffset = maxScrollPos
					this.wait = false
					this.isChangingChapter = false
					this.saveData(true)
				},
				fail: () => {
					this.wait = false
					this.isChangingChapter = false
				}
			})
		}, 300)
	},

	saveData(forceImmediate = false) {
		if (this.saveMode === 'periodic' && !forceImmediate) return
		if (this.saveDataTimeout) clearTimeout(this.saveDataTimeout)
		this.saveDataTimeout = setTimeout(() => {
			this._performSave()
		}, forceImmediate ? 0 : 300)
	},

	async _performSave() {
		if (!this.name || this.totalChapters === 0) return
		try {
			let progress = await bookStorage.get(this.name)
			if (!progress) progress = {}
			progress.chapterIndex = this.currentChapterIndexInAll
			if (this.readMode === 'nostalgic') {
				progress.offsetInChapter = Math.max(0, this.nostalgicSavedOffset || 0)
				progress.scrollOffset = this.nostalgicOffsetTopNormal || 0
			} else {
				progress.offsetInChapter = Math.max(0, Math.floor(this.currentFileOffset || 0))
				progress.scrollOffset = Math.max(0, Math.floor(this.currentScrollTop || 0))
			}
			progress.txtSizePage = this.txtSizePage
			progress.fontSize = this.fontSize
			progress.lastReadTimestamp = Date.now()
			progress.chapterProgressPercent = Math.min(100, Math.max(0, parseFloat(this.chapterProgress) || 0))
			await bookStorage.set(this.name, progress)
		} catch (e) { }
	},

	async onHide() {
		this.stopProximitySensor()
		if (this.saveDataTimeout) {
			clearTimeout(this.saveDataTimeout)
			this.saveDataTimeout = null
		}
		if (this.readingTimeSaveTimer) { clearInterval(this.readingTimeSaveTimer); this.readingTimeSaveTimer = null }
		if (this.autoInterval) clearInterval(this.autoInterval)
		if (this.timer) { clearInterval(this.timer); this.timer = null }
		await this._performSave()
		if (this.name) try { await readingTimeStorage.recordReadingEnd(this.name); } catch (e) { }
		brightness.setKeepScreenOn({ keepScreenOn: false })
	},

	async onDestroy() {
		if (this.saveDataTimeout) {
			clearTimeout(this.saveDataTimeout)
			this.saveDataTimeout = null
		}
		if (this.readingTimeSaveTimer) clearInterval(this.readingTimeSaveTimer)
		if (this.timer) clearInterval(this.timer)
		if (this.autoInterval) clearInterval(this.autoInterval)
		await this._performSave()
		if (this.name) try { await readingTimeStorage.recordReadingEnd(this.name); } catch (e) { }
		brightness.setKeepScreenOn({ keepScreenOn: false })
		global.runGC()
	},

	onBackPress() {
		const nostalgicSwipeEnabled = this.readMode === 'nostalgic' && this.nostalgicPageTurnMode === 'swipe'
		const scrollSwipeEnabled = this.readMode !== 'nostalgic' && this.chapterSwitchStyle === 'swipe'

		if (nostalgicSwipeEnabled) {
			this.turnNostalgicPage(-1)
			return true
		}

		if (scrollSwipeEnabled) {
			this.changeChapter(-1)
			return true
		}

		if (this.periodicSaveTimer) clearInterval(this.periodicSaveTimer)
		if (this.readingTimeSaveTimer) clearInterval(this.readingTimeSaveTimer)
		if (this.autoInterval) clearInterval(this.autoInterval)
		this._performSave()
		if (this.name) try { readingTimeStorage.recordReadingEnd(this.name) } catch (e) { }
		return false
	},

	async back() {
		if (this.saveDataTimeout) clearTimeout(this.saveDataTimeout)
		if (this.readingTimeSaveTimer) clearInterval(this.readingTimeSaveTimer)
		if (this.autoInterval) clearInterval(this.autoInterval)
		await this._performSave()
		if (this.name) try { await readingTimeStorage.recordReadingEnd(this.name); } catch (e) { }
		router.back()
	},

	async gotoSetting() {
		if (this.isProcessingClick) return
		this.isProcessingClick = true
		try {
			this.saveData(true)
			globalThis.readerChapterAllSize = this.allSize
			globalThis.readerChapterIndex = this.currentChapterIndexInAll
			globalThis.readerChapterProgressPercent = this.chapterProgress
			globalThis.readerTxtSizePage = this.txtSizePage
			if (this.readingTimeSaveTimer) {
				clearInterval(this.readingTimeSaveTimer)
				this.readingTimeSaveTimer = null
			}
			router.push({ uri: '/pages/detailsetting', params: { name: this.name } })
		} finally {
			setTimeout(() => { this.isProcessingClick = false }, 500)
		}
	},

	async exitAppForTeacherScreen() {
		if (this.saveDataTimeout) clearTimeout(this.saveDataTimeout)
		if (this.readingTimeSaveTimer) clearInterval(this.readingTimeSaveTimer)
		if (this.autoInterval) clearInterval(this.autoInterval)
		await this._performSave()
		if (this.name) try { await readingTimeStorage.recordReadingEnd(this.name) } catch (e) { }
		app.terminate()
	},

	loadNostalgicChapter(offsetInChapter) {
		this.nostalgicOffsetTopNormal = 0
		this.nostalgicOffsetTopPreview = 0
		this.nostalgicPreViewShowFlag = false
		this.nostalgicBoxAllHeightNormal = 0
		this.nostalgicBoxAllHeightPreview = 0
		this.nostalgicHeightCacheKey = ''
		this.clearNostalgicHistory()

		if (offsetInChapter === -1) {
			this.loadNostalgicEnd()
		} else {
			if (this._fromBookmark && this._bookmarkOffsetInChapter !== null) {
				this.nostalgicSavedOffset = this._bookmarkOffsetInChapter
				this.nostalgicOffsetTopNormal = this._bookmarkScrollOffset || 0
			} else if (this._fromPercent && this._percentTargetPercent !== null) {
				this.nostalgicSavedOffset = Math.floor(this._percentTargetPercent / 100 * this.allSize)
				this.nostalgicSavedOffset = this.nostalgicSavedOffset - (this.nostalgicSavedOffset % 2)
				this.nostalgicOffsetTopNormal = 0
			} else {
				this.nostalgicSavedOffset = this.currentFileOffset || 0
				if (!this._shouldScrollToTop && this.savedScrollOffset !== 0) {
					this.nostalgicOffsetTopNormal = this.savedScrollOffset
				}
			}
			this.readNostalgicText(this.nostalgicSavedOffset, (page) => {
				this.applyNostalgicPage(page, this.nostalgicSavedOffset)
			})
		}
	},

	loadNostalgicEnd() {
		this.wait = true
		const READ_LEN = this.txtSizePage * 2
		const offset = Math.max(0, this.allSize - READ_LEN)
		this.readNostalgicText(offset, (page) => {
			this.applyNostalgicPage(page, offset, true, () => {
				if (this.nostalgicPageType !== 'illustration') {
					this.nostalgicOffsetTopNormal = this.nostalgicBoxAllHeightNormal > this.pageHeigh ? (this.nostalgicBoxAllHeightNormal - this.pageHeigh) * -1 : 0
					this.resetNostalgicPageOffset()
				}
			})
		})
	},

	readNostalgicText(readOffset, cb) {
		const READ_LEN = this.txtSizePage * 2
		let length = READ_LEN
		if (readOffset >= this.allSize) { cb({ type: 'text', text: '', endOffset: readOffset }); return }
		if (readOffset < 0) { length += readOffset; readOffset = 0 }
		const maxLength = this.allSize - readOffset
		if (length > maxLength) length = maxLength

		file.readArrayBuffer({
			uri: this.cPath, position: readOffset, length: length,
			success: (data) => {
				if (!data.buffer || data.buffer.byteLength === 0) {
					cb({ type: 'text', text: '', endOffset: readOffset })
					return
				}
				try {
					const buffer = new Uint8Array(data.buffer)
					let bytesToUse = buffer.length

					if (readOffset === 0) {
						let prefix = ""
						if (this.chapterStartEmptyLines) prefix += "\n\n\n"
						if (this.chapterStartNumber) prefix += `第 ${this.currentChapterIndexInAll + 1} / ${this.totalChapters} 章\n`
						if (this.chapterStartName) prefix += `${this.currentChapterName}\n`
						if (this.chapterStartWordCount) prefix += `本章 ${this.currentChapterWordCount} 字\n`
						if (this.chapterStartName || this.chapterStartWordCount || this.chapterStartNumber) prefix += "\n"

						const prefixByteCount = prefix.length * 2
						if (prefixByteCount > 0 && (readOffset + buffer.length) < this.allSize) {
							bytesToUse = Math.max(0, buffer.length - prefixByteCount)
							bytesToUse = bytesToUse - (bytesToUse % 2)
						}
					}

					let str = this.encodeUtf16LEBuffer(buffer, bytesToUse)
					const markerStart = str.lastIndexOf('[[SINE_IMG|')
					if (markerStart >= 0 && str.indexOf(']]', markerStart) === -1) {
						str = str.slice(0, markerStart)
					}

					let prefix = ""
					if (readOffset === 0) {
						if (this.chapterStartEmptyLines) prefix += "\n\n\n"
						if (this.chapterStartNumber) prefix += `第 ${this.currentChapterIndexInAll + 1} / ${this.totalChapters} 章\n`
						if (this.chapterStartName) prefix += `${this.currentChapterName}\n`
						if (this.chapterStartWordCount) prefix += `本章 ${this.currentChapterWordCount} 字\n`
						if (this.chapterStartName || this.chapterStartWordCount || this.chapterStartNumber) prefix += "\n"
					}
					if (!this.illustrationEnabled) {
						str = illustrationUtil.stripIllustrationMarkers(str)
					}
					const firstIllustration = illustrationUtil.findFirstIllustration(str, this.name, this.illustrationEnabled)
					if (firstIllustration) {
						const textBeforeIllustration = prefix + str.slice(0, firstIllustration.startIndex)
						const hasVisibleTextBeforeIllustration =
							textBeforeIllustration.replace(/\s+/g, '').length > 0
						if (hasVisibleTextBeforeIllustration) {
							cb({
								type: 'text',
								text: textBeforeIllustration,
								endOffset: readOffset + firstIllustration.startIndex * 2
							})
						} else {
							cb({
								type: 'illustration',
								text: '',
								imageUri: firstIllustration.imageUri,
								altText: firstIllustration.altText || '插图',
								endOffset: readOffset + firstIllustration.rawLength * 2
							})
						}
						return
					}
					cb({
						type: 'text',
						text: prefix + str,
						endOffset: readOffset + bytesToUse
					})
				} catch (e) { cb({ type: 'text', text: '', endOffset: readOffset }); }
			},
			fail: () => { cb({ type: 'text', text: '', endOffset: readOffset }); }
		})
	},

	getNostalgicBoxHeight(id, cb, secondFlag = false) {
		const cacheKey = [
			this.nostalgicText ? this.nostalgicText.length : 0,
			this.fontSize,
			this.lineHeight,
			this.pageHeigh
		].join('|')

		if (this.nostalgicHeightCacheKey === cacheKey && this.nostalgicBoxAllHeightNormal > 0) {
			cb(this.nostalgicBoxAllHeightNormal)
			return
		}

		setTimeout(() => {
			const el = this.$element(id)
			if (!el) {
				cb(this.pageHeigh)
				return
			}
			el.getBoundingClientRect({
				success: (data) => {
					const height = data.height || 0
					if (height === 0 && !secondFlag) {
						this.getNostalgicBoxHeight(id, cb, true)
						return
					}
					const line = this.lineHeight > 0 ? this.lineHeight : 1
					const height2 = Math.ceil(height / line) * line
					this.nostalgicHeightCacheKey = cacheKey
					cb(height2)
				},
				fail: () => { cb(this.pageHeigh) }
			})
		}, 150)
	},

	resetNostalgicPageOffset() {
		if (this.nostalgicPageType === 'illustration') {
			this.nostalgicOffsetTopNormal = 0
			this.nostalgicBoxAllHeightNormal = this.pageHeigh
			this.updateNostalgicProgress()
			return
		}

		const READ_LEN = this.txtSizePage * 2
		this.nostalgicPreViewShowFlag = false

		if (this.nostalgicOffsetTopNormal > 0) {
			if (this.nostalgicSavedOffset <= 0) {
				this.nostalgicOffsetTopNormal = 0
				if (this.currentChapterIndexInAll > 0) {
					this.changeChapter(-1)
				} else {
					prompt.showToast({ message: '已是第一章' })
					this.isAtChapterStart = true
					this.updateNostalgicProgress()
				}
				return
			}

			const prevOffset = Math.max(0, this.nostalgicSavedOffset - READ_LEN)
			const carryOffset = this.nostalgicOffsetTopNormal
			this.wait = true
			this.readNostalgicText(prevOffset, (page) => {
				this.applyNostalgicPage(page, prevOffset, true, () => {
					if (this.nostalgicPageType !== 'illustration') {
						this.nostalgicOffsetTopNormal = carryOffset - this.nostalgicBoxAllHeightNormal
						if (prevOffset <= 0 && this.nostalgicOffsetTopNormal > 0) {
							this.nostalgicOffsetTopNormal = 0
							this.nostalgicSavedOffset = 0
						}
						this.wait = false
						this.resetNostalgicPageOffset()
					}
				})
			})
			return
		}

		const remain = this.nostalgicBoxAllHeightNormal + this.nostalgicOffsetTopNormal
		if (remain > 0) {
			if (this.nostalgicPageEndOffset >= this.allSize) {
				this.nostalgicOffsetTopNormal = this.nostalgicBoxAllHeightNormal > this.pageHeigh ? (this.nostalgicBoxAllHeightNormal - this.pageHeigh) * -1 : 0
			}
			this.updateNostalgicProgress()
			return
		}

		if (this.nostalgicPageEndOffset >= this.allSize) {
			this.nostalgicOffsetTopNormal -= remain
			if (this.currentChapterIndexInAll < this.totalChapters - 1) {
				this.changeChapter(1)
			} else {
				prompt.showToast({ message: '已是最后一章' })
				this.isAtChapterEnd = true
				this.updateNostalgicProgress()
			}
			return
		}

		const nextOffset = this.nostalgicPageEndOffset || (this.nostalgicSavedOffset + READ_LEN)
		const carryOffset = remain <= -this.pageHeigh ? (remain + this.pageHeigh) : 0
		this.wait = true
		this.nostalgicPageHistory.push(this.captureNostalgicPageState())
		this.readNostalgicText(nextOffset, (page) => {
			this.applyNostalgicPage(page, nextOffset, true, () => {
				if (this.nostalgicPageType !== 'illustration') {
					this.nostalgicOffsetTopNormal = carryOffset
					this.wait = false
					this.resetNostalgicPageOffset()
				}
			})
		})
	},

	updateNostalgicProgress() {
		const READ_LEN = this.txtSizePage * 2
		this.isAtChapterStart = (this.nostalgicSavedOffset === 0 && this.nostalgicOffsetTopNormal >= 0)
		if (this.nostalgicPageType === 'illustration') {
			this.isAtChapterEnd = this.nostalgicPageEndOffset >= this.allSize
			this.isNearTopForHd = this.isAtChapterStart
			if (this.allSize > 0) {
				const progressOffset = Math.min(this.allSize, Math.max(this.nostalgicSavedOffset, Math.floor((this.nostalgicSavedOffset + this.nostalgicPageEndOffset) / 2)))
				let newProg = Math.min(100, Math.max(0, (progressOffset / this.allSize) * 100))
				newProg = Math.round(newProg).toString()
				if (this.displayProgress !== newProg) this.displayProgress = newProg
			} else if (this.displayProgress !== '0') {
				this.displayProgress = '0'
			}
			this.saveData(true)
			return
		}
		const preOffset = this.nostalgicBoxAllHeightNormal + this.nostalgicOffsetTopNormal
		this.isAtChapterEnd = (this.nostalgicSavedOffset + READ_LEN >= this.allSize && preOffset <= 0)
		this.isNearTopForHd = this.isAtChapterStart

		if (this.allSize > 0) {
			const bytesPerPixel = READ_LEN / (this.nostalgicBoxAllHeightNormal || 1)
			const scrolled = this.nostalgicSavedOffset + (this.nostalgicOffsetTopNormal < 0 ? -this.nostalgicOffsetTopNormal * bytesPerPixel : 0)
			this.displayProgress = Math.min(100, Math.max(0, (scrolled / this.allSize) * 100))
		} else {
			this.displayProgress = 0
		}
		this.saveData(true)
	},

	onNostalgicTouchStart(e) {
		if (this.nostalgicPageTurnMode === 'swipe' || this.nostalgicPageTurnMode === 'topBottomSwipe') {
			this.nostalgicIsTouching = true
			this.nostalgicTouchStartX = e.touches[0].clientX
			this.nostalgicTouchStartY = e.touches[0].clientY
			this.nostalgicTouchEndX = e.touches[0].clientX
			this.nostalgicTouchEndY = e.touches[0].clientY
		}
		// Feature 3: Edge swipe detection for nostalgic mode
		if (this.edgeSwipeEnabled) {
			const touch = e.touches[0]
			if (touch.clientX >= 182) {
				this.edgeTouchActive = true
				this.edgeTouchStartX = touch.clientX
				this.edgeTouchStartY = touch.clientY
			}
		}
	},

	onNostalgicTouchMove(e) {
		if ((this.nostalgicPageTurnMode === 'swipe' || this.nostalgicPageTurnMode === 'topBottomSwipe') && this.nostalgicIsTouching) {
			this.nostalgicTouchEndX = e.touches[0].clientX
			this.nostalgicTouchEndY = e.touches[0].clientY
		}
	},

	onNostalgicTouchEnd(e) {
		if ((this.nostalgicPageTurnMode === 'swipe' || this.nostalgicPageTurnMode === 'topBottomSwipe') && this.nostalgicIsTouching) {
			this.nostalgicIsTouching = false
			const deltaX = this.nostalgicTouchEndX - this.nostalgicTouchStartX
			const deltaY = this.nostalgicTouchEndY - this.nostalgicTouchStartY
			if (this.nostalgicPageTurnMode === 'swipe') {
				if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > Math.abs(deltaY)) {
					if (deltaX < 0) this.turnNostalgicPage(1)
					else this.turnNostalgicPage(-1)
				}
			} else if (Math.abs(deltaY) > 50 && Math.abs(deltaY) > Math.abs(deltaX)) {
				if (deltaY < 0) this.turnNostalgicPage(1)
				else this.turnNostalgicPage(-1)
			}
		}
	},

	turnNostalgicPage(direction) {
		if (this.wait) return
		if (this.nostalgicPageType === 'illustration') {
			if (direction > 0) {
				if (this.nostalgicPageEndOffset >= this.allSize) {
					if (this.currentChapterIndexInAll < this.totalChapters - 1) {
						this.changeChapter(1)
					} else {
						prompt.showToast({ message: '已是最后一章' })
						this.isAtChapterEnd = true
						this.updateNostalgicProgress()
					}
					return
				}
				const nextOffset = this.nostalgicPageEndOffset
				this.wait = true
				this.nostalgicPageHistory.push(this.captureNostalgicPageState())
				this.readNostalgicText(nextOffset, (page) => {
					this.applyNostalgicPage(page, nextOffset)
				})
				return
			}

			const previousPage = this.nostalgicPageHistory.pop()
			if (previousPage) {
				this.nostalgicPageType = previousPage.type
				this.nostalgicText = previousPage.text
				this.nostalgicOffsetTopNormal = previousPage.offsetTop
				this.nostalgicSavedOffset = previousPage.savedOffset
				this.nostalgicPageEndOffset = previousPage.endOffset
				this.nostalgicBoxAllHeightNormal = previousPage.height
				this.nostalgicIllustrationUri = previousPage.imageUri
				this.nostalgicIllustrationAlt = previousPage.altText
				this.wait = false
				this.isChangingChapter = false
				this.updateNostalgicProgress()
				return
			}

			if (this.nostalgicSavedOffset <= 0) {
				if (this.currentChapterIndexInAll > 0) {
					this.changeChapter(-1)
				} else {
					prompt.showToast({ message: '已是第一章' })
					this.isAtChapterStart = true
					this.updateNostalgicProgress()
				}
				return
			}

			const fallbackOffset = Math.max(0, this.nostalgicSavedOffset - this.txtSizePage * 2)
			this.wait = true
			this.readNostalgicText(fallbackOffset, (page) => {
				this.applyNostalgicPage(page, fallbackOffset, true, () => {
					if (this.nostalgicPageType !== 'illustration') {
						this.nostalgicOffsetTopNormal = this.nostalgicBoxAllHeightNormal > this.pageHeigh ? (this.pageHeigh - this.nostalgicBoxAllHeightNormal) : 0
						this.wait = false
						this.resetNostalgicPageOffset()
					}
				})
			})
			return
		}

		if (direction > 0) {
			this.nostalgicOffsetTopNormal -= this.pageHeigh
			this.resetNostalgicPageOffset()
		} else {
			this.nostalgicOffsetTopNormal += this.pageHeigh
			this.resetNostalgicPageOffset()
		}
	},

	onNostalgicClick(event) {
		this.handleGeneralClick(event, (evt) => {
			if (this.isChangingChapter) return
			if (this.wait) {
				this.showSetting = !this.showSetting
				return
			}

			if (this.nostalgicPageTurnMode === 'swipe' || this.nostalgicPageTurnMode === 'topBottomSwipe') {
				this.showSetting = !this.showSetting
			} else {
				const isTopBottom = this.nostalgicPageTurnMode === 'topBottomClick'
				const clickPos = isTopBottom ? (evt.offsetY || (evt.detail && evt.detail.y) || 0) : (evt.offsetX || (evt.detail && evt.detail.x) || 0)
				const dim = isTopBottom ? 520 : 212
				if (clickPos < dim / 3) this.turnNostalgicPage(-1)
				else if (clickPos > dim * 2 / 3) this.turnNostalgicPage(1)
				else this.showSetting = !this.showSetting
			}
		})
	},

	onTxtClick(event) {
		this.handleGeneralClick(event, (evt) => {
			if (this.isChangingChapter) return
			if (this.wait) {
				this.showSetting = !this.showSetting
				return
			}

			if (this.swipe === 'column') {
				this.showSetting = !this.showSetting
			} else {
				if (this.showSetting) this.showSetting = false
				else if (evt.offsetY <= 158) this.lastPage()
				else if (evt.offsetY <= 322) this.showSetting = true
				else this.nextPage()
			}
		})
	},

	handleGeneralClick(event, actionCallback) {
		if (this.teacherScreenEnabled) {
			this.clickCount++
			if (this.clickTimeout) clearTimeout(this.clickTimeout)
			if (this.clickCount >= 3) {
				this.clickCount = 0
				this.exitAppForTeacherScreen()
				return
			}
			this.clickTimeout = setTimeout(() => { this.clickCount = 0 }, 500)
		}

		if (this.gestureMode === 'double') {
			this.gestureClickCount++
			if (this.gestureClickTimeout) clearTimeout(this.gestureClickTimeout)
			if (this.gestureClickCount === 2) {
				this.gestureClickCount = 0
				this.showSetting = !this.showSetting
			} else {
				this.gestureClickTimeout = setTimeout(() => {
					this.gestureClickCount = 0
				}, 300)
			}
		} else {
			if (this.showSetting) this.showSetting = false
			else actionCallback(event)
		}
	},

	onTxtLongPress(event) {
		if (this.auto) {
			// UX: Auto speed control - long press top/bottom to adjust speed
			if (this.uxAutoSpeedControl && this.autoInterval) {
				const y = event.offsetY || (event.detail && event.detail.y) || 260
				if (y < 173) {
					// Top area: speed up
					const newSpeed = Math.max(1, this.auto - 0.5)
					this.auto = newSpeed
					clearInterval(this.autoInterval)
					this.autoInterval = setInterval(() => {
						if (this.wait) return
						if (this.readMode === 'nostalgic') this.turnNostalgicPage(1)
						else if (this.isAtChapterEnd) this.changeChapter(1)
						else this.nextPage()
					}, this.auto * 1000)
					prompt.showToast({ message: `自动翻页: ${this.auto}秒` })
					return
				} else if (y > 347) {
					// Bottom area: slow down
					const newSpeed = Math.min(10, this.auto + 0.5)
					this.auto = newSpeed
					clearInterval(this.autoInterval)
					this.autoInterval = setInterval(() => {
						if (this.wait) return
						if (this.readMode === 'nostalgic') this.turnNostalgicPage(1)
						else if (this.isAtChapterEnd) this.changeChapter(1)
						else this.nextPage()
					}, this.auto * 1000)
					prompt.showToast({ message: `自动翻页: ${this.auto}秒` })
					return
				}
				// Middle: fall through to toggle off
			}
			if (this.autoInterval) {
				clearInterval(this.autoInterval)
				this.autoInterval = null
				prompt.showToast({ message: '已关闭自动翻页' })
				if (this.keepScreenOnByAuto) {
					this.keepScreenOnByAuto = false
					this.isKeepScreenOn = false
					brightness.setKeepScreenOn({ keepScreenOn: false })
				}
				return
			}
			this.autoInterval = setInterval(() => {
				if (this.wait) return
				if (this.readMode === 'nostalgic') this.turnNostalgicPage(1)
				else if (this.isAtChapterEnd) this.changeChapter(1)
				else this.nextPage()
			}, this.auto * 1000)
			prompt.showToast({ message: '已开启自动翻页' })
			if (!this.isKeepScreenOn) {
				this.keepScreenOnByAuto = true
				this.isKeepScreenOn = true
				brightness.setKeepScreenOn({ keepScreenOn: true })
			}
		}
	},

	onTitleClick() {
		this.titleClickCount++
		if (this.titleClickTimeout) clearTimeout(this.titleClickTimeout)

		this.titleClickTimeout = setTimeout(() => {
			if (this.titleClickCount === 2 && this.shortcutDoubleClickBookmark) {
				this.addBookmark()
			} else if (this.titleClickCount === 3 && this.shortcutTripleClickBookmarkManager) {
				router.push({ uri: '/pages/bookmarks', params: { name: this.name } })
			}
			this.titleClickCount = 0
			this.titleClickTimeout = null
		}, 400)
	},

	onTitleLongPress() {
		if (this.shortcutLongPressScreenOn) {
			this.toggleKeepScreenOn()
		}
	},

	lastPage() {
		const scrollEl = this.$element("scrollId")
		if (!scrollEl) return
		const delta = this.pageHeigh * (this.autoReadDistance / 100)
		const nextTop = Math.max(0, this.currentScrollTop - delta)
		this.scrollTopValue = nextTop
		this.savedScrollOffset = nextTop
		scrollEl.scrollTo({ top: nextTop, behavior: 'smooth' })
	},

	nextPage() {
		const scrollEl = this.$element("scrollId")
		if (!scrollEl) return
		const delta = this.pageHeigh * (this.autoReadDistance / 100)
		const nextTop = Math.max(0, this.currentScrollTop + delta)
		this.scrollTopValue = nextTop
		this.savedScrollOffset = nextTop
		scrollEl.scrollTo({ top: nextTop, behavior: 'smooth' })
	},

	applyKeepScreenOnState() {
		globalThis.isKeepScreenOn = this.isKeepScreenOn
		brightness.setKeepScreenOn({ keepScreenOn: this.isKeepScreenOn })
	},

	toggleKeepScreenOn() {
		this.isKeepScreenOn = !this.isKeepScreenOn
		this.keepScreenOnByAuto = false
		this.applyKeepScreenOnState()
		prompt.showToast({ message: this.isKeepScreenOn ? '已开启屏幕常亮' : '已关闭屏幕常亮' })
	},

	async addBookmark() {
		if (this.isProcessingClick) return
		this.isProcessingClick = true

		let bookmarks = await bookStorage.getBookmarks(this.name) || []
		const chapter = await chapterManager.getChapterByIndex(this.name, this.currentChapterIndexInAll)
		if (!chapter || chapter.index === undefined) {
			prompt.showToast({ message: '无法添加书签，章节信息错误' })
			this.isProcessingClick = false
			return
		}

		bookmarks.push({
			chapterIndex: chapter.index,
			chapterName: this.currentChapterName,
			offsetInChapter: this.readMode === 'nostalgic' ? this.nostalgicSavedOffset : Math.max(0, Math.floor(this.currentFileOffset || 0)),
			scrollOffset: this.readMode === 'nostalgic' ? this.nostalgicOffsetTopNormal : Math.max(0, Math.floor(this.currentScrollTop || 0)),
			time: new Date().getTime(),
			name: `书签${bookmarks.length + 1}`
		})
		bookmarks.sort((a, b) => a.chapterIndex - b.chapterIndex || a.offsetInChapter - b.offsetInChapter)
		try {
			await bookStorage.setBookmarks(this.name, bookmarks)
			prompt.showToast({ message: '添加书签成功' })
		} catch (e) {
			prompt.showToast({ message: '添加书签失败' })
		}
		this.isProcessingClick = false
	},

	gotoBookmarks() {
		if (this.isProcessingClick) return
		this.isProcessingClick = true
		this.longPressTriggered = true
		if (this.longPressTimeout) clearTimeout(this.longPressTimeout)
		this.longPressTimeout = setTimeout(() => {
			this.longPressTriggered = false
			this.longPressTimeout = null
		}, 300)
		this.saveData(true)
		router.push({ uri: '/pages/bookmarks', params: { name: this.name } })
		setTimeout(() => { this.isProcessingClick = false }, 500)
	},

	// Feature 2: Teacher screen advanced - proximity sensor
	startProximitySensor() {
		// Monitor screen state: poll brightness; if screen off detected, exit
		var self = this
		this._teacherScreenCheckInterval = setInterval(function() {
			if (!self.teacherScreenAdvanced) return
			if (!self.isKeepScreenOn) return
			try {
				brightness.getValue({
					success: function(data) {
						// If brightness is 0 or very low, screen might be off
						if (data.value !== undefined && data.value <= 0) {
							self.exitAppForTeacherScreen()
						}
					},
					fail: function() {
						// If we can't read brightness, screen is likely off
						self.exitAppForTeacherScreen()
					}
				})
			} catch (e) {}
		}, 2000)
	},

	stopProximitySensor() {
		if (this._teacherScreenCheckInterval) {
			clearInterval(this._teacherScreenCheckInterval)
			this._teacherScreenCheckInterval = null
		}
		this.proximityCoveredTime = 0
	},

	// Feature 3: Edge swipe touch handling
	onEdgeTouchStart(e) {
		if (!this.edgeSwipeEnabled) return
		const touch = e.touches[0]
		// Right edge 30px
		if (touch.clientX >= 182) {
			this.edgeTouchActive = true
			this.edgeTouchStartX = touch.clientX
			this.edgeTouchStartY = touch.clientY
		}
	},

	onEdgeTouchMove(e) {
		if (!this.edgeTouchActive) return
		// nothing needed
	},

	onEdgeTouchEnd(e) {
		if (!this.edgeTouchActive) return
		this.edgeTouchActive = false
		const touch = e.changedTouches[0]
		const deltaX = touch.clientX - this.edgeTouchStartX
		// Left swipe > 50px
		if (deltaX < -50) {
			this.triggerEdgeSwipeAction()
		}
	},

	triggerEdgeSwipeAction() {
		if (this.vibrateOnTouch) {
			try { vibrator.vibrate({ mode: 'short' }) } catch (e) {}
		}
		switch (this.edgeSwipeAction) {
			case 'bookmarks':
				router.push({ uri: '/pages/bookmarks', params: { name: this.name } })
				break
			case 'bookinfo':
				router.push({ uri: '/pages/bookinfo', params: { name: this.name } })
				break
			case 'more':
				router.push({ uri: '/pages/more' })
				break
			case 'brightness':
				router.push({ uri: '/pages/screenBrightness' })
				break
			case 'chapterList':
				router.push({ uri: '/pages/list', params: { name: this.name } })
				break
			case 'readingTime':
				router.push({ uri: '/pages/readingTime' })
				break
			case 'share':
				router.push({ uri: '/pages/shareDetail', params: { name: this.name, chapterIndex: this.currentChapterIndexInAll } })
				break
			default:
				router.push({ uri: '/pages/bookmarks', params: { name: this.name } })
		}
	},

	// Feature 4: Vibrate on chapter switch
	vibrateOnChapterSwitch() {
		if (this.vibrateChapterSwitch) {
			try { vibrator.vibrate({ mode: 'short' }) } catch (e) {}
		}
	},

	// Feature 6: Bookmark jump with temp position
	async jumpToBookmarkWithTemp(bookmark) {
		// Save original progress
		const progress = await bookStorage.get(this.name)
		globalThis._originalReadingProgress = {
			chapterIndex: progress.chapterIndex,
			offsetInChapter: progress.offsetInChapter,
			scrollOffset: progress.scrollOffset,
			name: this.name
		}
		// Jump to bookmark
		const progressData = {
			chapterIndex: bookmark.chapterIndex !== undefined ? parseInt(bookmark.chapterIndex) : null,
			offsetInChapter: typeof bookmark.offsetInChapter === 'number' ? Math.max(0, Math.floor(bookmark.offsetInChapter)) : 0,
			scrollOffset: typeof bookmark.scrollOffset === 'number' ? Math.max(0, Math.floor(bookmark.scrollOffset)) : 0
		}
		await bookStorage.set(this.name, progressData)
		globalThis.justJumpedFromBookmark = true
		globalThis.justJumpedBookmarkChapterIndex = progressData.chapterIndex
		this.showSetting = false
		this.loadBook()
	},

	async restoreOriginalProgress() {
		if (globalThis._originalReadingProgress) {
			const orig = globalThis._originalReadingProgress
			await bookStorage.set(orig.name, {
				chapterIndex: orig.chapterIndex,
				offsetInChapter: orig.offsetInChapter,
				scrollOffset: orig.scrollOffset
			})
			globalThis.justJumpedFromBookmark = true
			globalThis.justJumpedBookmarkChapterIndex = orig.chapterIndex
			globalThis._originalReadingProgress = null
			this.loadBook()
		}
	},

	stayAtBookmarkPosition() {
		globalThis._originalReadingProgress = null
		prompt.showToast({ message: '已停留在书签位置' })
	},

	// Feature 7: Long press more button → global settings
	onMoreLongPress() {
		this.moreLongPressTriggered = true
		if (this.moreLongPressTimer) clearTimeout(this.moreLongPressTimer)
		if (this.vibrateOnTouch) {
			try { vibrator.vibrate({ mode: 'short' }) } catch (e) {}
		}
		router.push({ uri: '/pages/more' })
	},

	onMoreClick() {
		if (this.moreLongPressTriggered) {
			this.moreLongPressTriggered = false
			return
		}
		this.gotoSetting()
	}
}
</script>

<style>
.page {
	width: 212px;
	height: 520px;
	background-color: #000000;
}

.progress-bar-container {
	position: absolute;
	bottom: 0px;
	width: 212px;
	justify-content: center;
	align-items: center;
}

.progress-bar-percent {
	position: absolute;
	left: 0px;
	width: 212px;
	text-align: center;
	color: rgba(255, 255, 255, 0.6);
	font-size: 14px;
	font-weight: bold;
}
</style>
